	-- =================================================================
	-- MODULE WORKFLOW AND CREATOR API
	-- =================================================================
	function GhostLib:CreateTab(tabName)
		local TabButton = Instance.new("TextButton")
		TabButton.Size = UDim2.new(1, 0, 0, 36)
		TabButton.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
		TabButton.Text = tabName
		TabButton.Font = Enum.Font.Montserrat
		TabButton.TextColor3 = Color3.fromRGB(120, 120, 120)
		TabButton.TextSize = 13
		TabButton.Parent = TabButtonsContainer
		Instance.new("UICorner", TabButton).CornerRadius = UDim.new(0, 6)
		local tStroke = Instance.new("UIStroke", TabButton)
		tStroke.Color = Color3.fromRGB(230, 230, 230)
		tStroke.Thickness = 1

		local TabContent = Instance.new("ScrollingFrame")
		TabContent.Size = UDim2.new(1, -32, 1, -32)
		TabContent.Position = UDim2.new(0, 16, 0, 16)
		TabContent.BackgroundTransparency = 1
		TabContent.Visible = false
		TabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
		TabContent.ScrollBarThickness = 3
		TabContent.ScrollBarImageColor3 = Color3.fromRGB(200, 200, 200)
		TabContent.Parent = TabsFolder

		local ContentLayout = Instance.new("UIListLayout")
		ContentLayout.Padding = UDim.new(0, 8)
		ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
		ContentLayout.Parent = TabContent

		ContentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			TabContent.CanvasSize = UDim2.new(0, 0, 0, ContentLayout.AbsoluteContentSize.Y + 15)
		end)

		if isFirstTab then
			TabContent.Visible = true
			TabContent.Size = UDim2.new(1, -32, 1, -32)
			TabButton.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
			TabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
			isFirstTab = false
		end

		TabButton.MouseButton1Click:Connect(function()
			for _, child in pairs(TabsFolder:GetChildren()) do
				child.Visible = false
			end
			for _, btn in pairs(TabButtonsContainer:GetChildren()) do
				if btn:IsA("TextButton") then
					TweenService:Create(btn, TweenInfo.new(0.2), {
						BackgroundColor3 = Color3.fromRGB(245, 245, 245),
						TextColor3 = Color3.fromRGB(120, 120, 120)
					}):Play()
				end
			end
			
			TabContent.Visible = true
			TabContent.Size = UDim2.new(1, -32, 1, -100)
			TweenService:Create(TabContent, TweenInfo.new(0.35, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
				Size = UDim2.new(1, -32, 1, -32)
			}):Play()

			TweenService:Create(TabButton, TweenInfo.new(0.2), {
				BackgroundColor3 = Color3.fromRGB(15, 15, 15)
			    ,TextColor3 = Color3.fromRGB(255, 255, 255)
			}):Play()
		end)

		local ElementCreator = {}

		function ElementCreator:CreateToggle(name, default, callback)
			local enabled = default or false
			local base, lbl = CreateElementBase(name, TabContent)
			
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(0, 44, 0, 22)
			btn.Position = UDim2.new(1, -60, 0.5, -11)
			btn.BackgroundColor3 = enabled and Color3.fromRGB(15, 15, 15) or Color3.fromRGB(220, 220, 220)
			btn.Text = ""
			btn.Parent = base
