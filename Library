			Size = UDim2.new(0, C.WINDOW_WIDTH, 0, 0),
			GroupTransparency = 1
		})
		t:Play()
		t.Completed:Connect(function()
			-- Disconnect all tracked connections
			for _, conn in ipairs(_connections) do
				pcall(function() conn:Disconnect() end)
			end
			ScreenGui:Destroy()
		end)
	end)

