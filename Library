	-- Drag Implementation
	local dragging, dragInput, dragStart, startPos
	TopBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = MainFrame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	TopBar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	-- Run Loop for biological tracking intro
	local introDuration = 4.0
	local ghostTween = TweenService:Create(Ghost, TweenInfo.new(introDuration, Enum.EasingStyle.Linear), {
		Position = UDim2.new(0, 660, 0.5, -55)
	})
	ghostTween:Play()

	local runTime = 0
	local processingConnection
	processingConnection = RunService.Heartbeat:Connect(function(deltaTime)
		runTime = runTime + deltaTime
		local speedScale = 3.2
		local phaseAngle = (runTime * speedScale * math.pi * 2)

		local normalW, normalH = 85, 110
		local deltaWidth = math.sin(phaseAngle) * 14
		local deltaHeight = -math.sin(phaseAngle) * 12

		if Ghost and Ghost:IsDescendantOf(game) then
			Ghost.Size = UDim2.new(0, normalW + deltaWidth, 0, normalH + deltaHeight)
			
			for positionIdx, tentacleNode in ipairs(Tentacles) do
				local varianceOffset = positionIdx * 0.4
				local calculatedSwing = math.cos(phaseAngle + varianceOffset) * 28
				local dynamicLength = 22 + (math.sin(phaseAngle + varianceOffset) * 9)
				
				tentacleNode.Rotation = calculatedSwing
				tentacleNode.Size = UDim2.new(waveWidth, 2, 0, dynamicLength)
			end
		end

		local currentGhostCenterX = Ghost.AbsolutePosition.X + (Ghost.AbsoluteSize.X / 2)
		for _, data in ipairs(LetterObjects) do
			if not data.Hit then
				local letterCenterX = data.Container.AbsolutePosition.X + (data.Container.AbsoluteSize.X / 2)
				if currentGhostCenterX >= letterCenterX then
					data.Hit = true
					task.spawn(function()
						local startPositionValue = data.Label.Position
						local layoutFallDropY = startPositionValue + UDim2.new(0, 0, 0, 45)
						
						TweenService:Create(data.Label, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							Position = layoutFallDropY,
							Rotation = 180,
							TextColor3 = Color3.fromRGB(240, 240, 240)
						}):Play()
						
						TweenService:Create(data.Stroke, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							Thickness = 3.5,
							Transparency = 0
						}):Play()

						task.wait(0.35)

						TweenService:Create(data.Label, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
							Position = startPositionValue,
							Rotation = 360
						}):Play()
					end)
				end
			end
		end
	end)

	task.delay(introDuration, function()
		if processingConnection then processingConnection:Disconnect() end
		
		local transitionCanvasFade = TweenService:Create(IntroContainer, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
