			GlowStroke.Parent = TextLabel

			table.insert(LetterObjects, {
				Container = LetterContainer,
				Label = TextLabel,
				Stroke = GlowStroke,
				Hit = false
			})
		end

		local Ghost = Instance.new("CanvasGroup")
		Ghost.Name = "Ghost"
		Ghost.Size = UDim2.new(0, 85, 0, 110)
		Ghost.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
		Ghost.ZIndex = 105
		Ghost.Parent = TextSequenceFrame
		Ghost.Position = UDim2.new(0, -160, 0.5, -55)
		RoundFrame(Ghost, 42)

		local Eye1 = Instance.new("Frame")
		Eye1.Size = UDim2.new(0, 9, 0, 13)
		Eye1.Position = UDim2.new(0.32, -4, 0.38, -6)
		Eye1.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
		Eye1.BorderSizePixel = 0
		Eye1.Parent = Ghost
		RoundFrame(Eye1, 999)

		local Eye2 = Eye1:Clone()
		Eye2.Position = UDim2.new(0.68, -4, 0.38, -6)
		Eye2.Parent = Ghost

		local Mouth = Instance.new("Frame")
		Mouth.Size = UDim2.new(0, 11, 0, 11)
		Mouth.Position = UDim2.new(0.5, -5, 0.58, -5)
		Mouth.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
		Mouth.BorderSizePixel = 0
		Mouth.Parent = Ghost
		RoundFrame(Mouth, 999)

		local Tentacles = {}
		local waveWidth = 1 / 5
		for i = 1, 5 do
			local wave = Instance.new("Frame")
			wave.Size = UDim2.new(waveWidth, 2, 0, 22)
			wave.Position = UDim2.new(waveWidth * (i - 1), -1, 1, -10)
			wave.BackgroundColor3 = (i == 2 or i == 4)
				and Color3.fromRGB(15, 15, 15)
				or Color3.fromRGB(245, 245, 245)
			wave.BorderSizePixel = 0
			wave.Parent = Ghost
			RoundFrame(wave, 999)
			table.insert(Tentacles, wave)
		end

		local ghostTween = Tween(Ghost,
			TweenInfo.new(introDur, Enum.EasingStyle.Linear),
			{Position = UDim2.new(0, 660, 0.5, -55)}
		)
		ghostTween:Play()

		local runTime = 0
		local animConn
		animConn = RunService.Heartbeat:Connect(function(dt)
			runTime += dt
			local phase = runTime * 3.2 * math.pi * 2

			if Ghost and Ghost:IsDescendantOf(game) then
				Ghost.Size = UDim2.new(0, 85 + math.sin(phase)*14, 0, 110 - math.sin(phase)*12)
				for idx, wave in ipairs(Tentacles) do
					local v = idx * 0.4
					wave.Rotation = math.cos(phase + v) * 28
					wave.Size = UDim2.new(waveWidth, 2, 0, 22 + math.sin(phase + v)*9)
				end
			end

			local gx = Ghost.AbsolutePosition.X + Ghost.AbsoluteSize.X / 2
			for _, data in ipairs(LetterObjects) do
				if not data.Hit then
					local lx = data.Container.AbsolutePosition.X + data.Container.AbsoluteSize.X / 2
					if gx >= lx then
						data.Hit = true
						task.spawn(function()
							local orig = data.Label.Position
							Tween(data.Label, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
								Position = orig + UDim2.new(0,0,0,45),
								Rotation = 180,
								TextColor3 = Color3.fromRGB(15,15,15)
							}):Play()
							Tween(data.Stroke, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
								Thickness = 3.5, Transparency = 0
							}):Play()
							task.wait(0.35)
							Tween(data.Label, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
								Position = orig, Rotation = 360
							}):Play()
						end)
					end
				end
			end
		end)

		task.delay(introDur, function()
			animConn:Disconnect()
			for _, data in ipairs(LetterObjects) do
				Tween(data.Label,  C.TWEEN_MED, {TextTransparency = 1}):Play()
				Tween(data.Stroke, C.TWEEN_MED, {Transparency = 1}):Play()
			end
			Tween(Ghost, C.TWEEN_MED, {GroupTransparency = 1}):Play()
			local fade = Tween(IntroContainer, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
			fade:Play()
			fade.Completed:Connect(function()
				IntroGui:Destroy()
				onComplete()
			end)
		end)
	end

