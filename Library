		-- ── DROPDOWN (single select) ────────────────────────────────────────
		--- Select one item from a list.
		--- @param name     string
		--- @param list     table    Non-empty array of option strings.
		--- @param callback function(selected: string)
		--- @return {Set:function, Get:function}
		function Tab:CreateDropdown(name, list, callback)
			assert(type(name)     == "string",                    "CreateDropdown: name must be a string")
			assert(type(list)     == "table" and #list > 0,       "CreateDropdown '" .. name .. "': list must be a non-empty table")
			assert(type(callback) == "function",                  "CreateDropdown '" .. name .. "': callback must be a function")

			local base, lbl = CreateElementBase(name, ScrollFrame, C.ELEM_HEIGHT)
			local expanded  = false
			local selected  = nil

			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(0, 150, 0, 28)
			btn.Position = UDim2.new(1, -166, 0, 9)
			btn.BackgroundColor3 = T.Input
			btn.FontFace = Font.new("rbxasset://fonts/families/Montserrat.json")
			btn.Text = "Select..."
			btn.TextColor3 = T.TextSecondary
			btn.TextSize = 12
			btn.Parent = base
			RoundFrame(btn, 6)
			local bStroke = Stroke(btn, T.InputBorder)

			local listFrame = Instance.new("ScrollingFrame")
			listFrame.Size = UDim2.new(0, 150, 0, 0)
			listFrame.Position = UDim2.new(1, -166, 0, 42)
			listFrame.BackgroundColor3 = T.Dropdown
			listFrame.BorderSizePixel = 0
			listFrame.Visible = false
			listFrame.ClipsDescendants = true
			listFrame.ZIndex = 20
			listFrame.ScrollBarThickness = 2
			listFrame.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 80)
			listFrame.CanvasSize = UDim2.new(0, 0, 0, #list * 28)
			listFrame.Parent = base
			RoundFrame(listFrame, 6)
			Stroke(listFrame, T.Border)
			Instance.new("UIListLayout").Parent = listFrame

			local function Collapse()
				expanded = false
				local t = Tween(listFrame, C.TWEEN_MED, {Size = UDim2.new(0, 150, 0, 0)})
				t:Play()
				Tween(base,    C.TWEEN_MED,  {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT)}):Play()
				Tween(bStroke, C.TWEEN_FAST, {Color = T.InputBorder}):Play()
				t.Completed:Once(function()
					if not expanded then listFrame.Visible = false end
				end)
			end

			local function Expand()
				expanded = true
				listFrame.Visible = true
				local h = math.min(#list * 28, 112)
				Tween(listFrame, C.TWEEN_CUBIC, {Size = UDim2.new(0, 150, 0, h)}):Play()
				Tween(base,      C.TWEEN_CUBIC, {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT + 6 + h)}):Play()
				Tween(bStroke,   C.TWEEN_FAST,  {Color = T.BorderFocus}):Play()
			end

			for _, item in pairs(list) do
				local itemBtn = Instance.new("TextButton")
				itemBtn.Size = UDim2.new(1, 0, 0, 28)
				itemBtn.BackgroundTransparency = 1
				itemBtn.Text = tostring(item)
				itemBtn.FontFace = Font.new("rbxasset://fonts/families/Montserrat.json")
				itemBtn.TextColor3 = T.TextMuted
				itemBtn.TextSize = 12
				itemBtn.ZIndex = 21
				itemBtn.Parent = listFrame

				itemBtn.MouseEnter:Connect(function()
					Tween(itemBtn, C.TWEEN_FAST, {BackgroundColor3 = T.DropdownSel, BackgroundTransparency = 0}):Play()
					Tween(itemBtn, C.TWEEN_FAST, {TextColor3 = T.DropdownSelTx}):Play()
				end)
				itemBtn.MouseLeave:Connect(function()
					if selected ~= item then
						Tween(itemBtn, C.TWEEN_FAST, {BackgroundTransparency = 1}):Play()
						Tween(itemBtn, C.TWEEN_FAST, {TextColor3 = T.TextMuted}):Play()
					end
				end)
				itemBtn.MouseButton1Click:Connect(function()
					selected = item
					btn.Text = tostring(item)
					Collapse()
					local ok2, err = pcall(callback, item)
					if not ok2 then
						warn("GhostLib Dropdown '" .. name .. "' callback error: " .. tostring(err))
					end
				end)
			end

			btn.MouseButton1Click:Connect(function()
				if expanded then Collapse() else Expand() end
			end)

			local api = {}
			function api:Set(val) selected = val; btn.Text = tostring(val) end
			function api:Get()    return selected end
			return api
		end

		-- ── MULTI-DROPDOWN ─────────────────────────────────────────────────
		--- Select zero or more items from a list.
		--- @param name     string
		--- @param list     table    Non-empty array.
		--- @param options  table?   { CloseOnSelect = true/false }
		--- @param callback function(selected: table)
		--- @return {Get:function, Clear:function}
		function Tab:CreateMultiDropdown(name, list, options, callback)
			-- Flexible argument order: options may be omitted
			if type(options) == "function" then
				callback = options
				options  = {}
			end
			options = options or {}
			local closeOnSelect = options.CloseOnSelect == true

			assert(type(name)     == "string",                   "CreateMultiDropdown: name must be a string")
			assert(type(list)     == "table" and #list > 0,      "CreateMultiDropdown '" .. name .. "': list must be a non-empty table")
			assert(type(callback) == "function",                 "CreateMultiDropdown '" .. name .. "': callback must be a function")

			local base, lbl = CreateElementBase(name, ScrollFrame, C.ELEM_HEIGHT)
			local expanded  = false
			local selected  = {}

			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(0, 150, 0, 28)
			btn.Position = UDim2.new(1, -166, 0, 9)
			btn.BackgroundColor3 = T.Input
			btn.FontFace = Font.new("rbxasset://fonts/families/Montserrat.json")
			btn.Text = "Multiple..."
			btn.TextColor3 = T.TextSecondary
			btn.TextSize = 12
			btn.Parent = base
			RoundFrame(btn, 6)
			local bStroke = Stroke(btn, T.InputBorder)

			local listFrame = Instance.new("ScrollingFrame")
			listFrame.Size = UDim2.new(0, 150, 0, 0)
			listFrame.Position = UDim2.new(1, -166, 0, 42)
			listFrame.BackgroundColor3 = T.Dropdown
			listFrame.BorderSizePixel = 0
			listFrame.Visible = false
			listFrame.ClipsDescendants = true
			listFrame.ZIndex = 20
			listFrame.ScrollBarThickness = 2
			listFrame.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 80)
			listFrame.CanvasSize = UDim2.new(0, 0, 0, #list * 28)
			listFrame.Parent = base
			RoundFrame(listFrame, 6)
			Stroke(listFrame, T.Border)
			Instance.new("UIListLayout").Parent = listFrame

			local function UpdateBtnText()
				if #selected == 0 then
					btn.Text = "Multiple..."
				else
					local t = table.concat(selected, ", ")
					btn.Text = #t > 16 and string.sub(t, 1, 13) .. "…" or t
				end
			end

			local function Collapse()
				expanded = false
				local t = Tween(listFrame, C.TWEEN_MED, {Size = UDim2.new(0, 150, 0, 0)})
				t:Play()
				Tween(base,    C.TWEEN_MED,  {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT)}):Play()
				Tween(bStroke, C.TWEEN_FAST, {Color = T.InputBorder}):Play()
				t.Completed:Once(function()
					if not expanded then listFrame.Visible = false end
				end)
			end

			local function Expand()
				expanded = true
				listFrame.Visible = true
				local h = math.min(#list * 28, 112)
				Tween(listFrame, C.TWEEN_CUBIC, {Size = UDim2.new(0, 150, 0, h)}):Play()
				Tween(base,      C.TWEEN_CUBIC, {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT + 6 + h)}):Play()
				Tween(bStroke,   C.TWEEN_FAST,  {Color = T.BorderFocus}):Play()
			end

			for _, item in pairs(list) do
				local itemBtn = Instance.new("TextButton")
				itemBtn.Size = UDim2.new(1, 0, 0, 28)
				itemBtn.BackgroundColor3 = T.DropdownItem
				itemBtn.BackgroundTransparency = 0
				itemBtn.BorderSizePixel = 0
				itemBtn.Text = tostring(item)
				itemBtn.FontFace = Font.new("rbxasset://fonts/families/Montserrat.json")
				itemBtn.TextColor3 = T.TextMuted
				itemBtn.TextSize = 12
				itemBtn.ZIndex = 21
				itemBtn.Parent = listFrame

				itemBtn.MouseButton1Click:Connect(function()
					local idx = table.find(selected, item)
					if idx then
						table.remove(selected, idx)
						Tween(itemBtn, C.TWEEN_FAST, {
							TextColor3       = T.TextMuted,
							BackgroundColor3 = T.DropdownItem,
						}):Play()
					else
						table.insert(selected, item)
						Tween(itemBtn, C.TWEEN_FAST, {
							TextColor3       = T.DropdownSelTx,
							BackgroundColor3 = T.DropdownSel,
						}):Play()
					end
					UpdateBtnText()
					local ok2, err = pcall(callback, selected)
					if not ok2 then
						warn("GhostLib MultiDropdown '" .. name .. "' callback error: " .. tostring(err))
					end
					if closeOnSelect then Collapse() end
				end)
			end

			btn.MouseButton1Click:Connect(function()
				if expanded then Collapse() else Expand() end
			end)

			local api = {}
			function api:Get()   return selected end
			function api:Clear() selected = {}; UpdateBtnText() end
			return api
		end

		-- ── COLOR PICKER ───────────────────────────────────────────────────
		--- Lightweight hue strip + brightness bar color picker.
		--- HSV inputs are automatically clamped to [0,1].
		--- @param name     string
		--- @param default  Color3?   Defaults to white.
		--- @param callback function(color: Color3)
		--- @return {Set:function, Get:function}
		function Tab:CreateColorPicker(name, default, callback)
			assert(type(name)     == "string",   "CreateColorPicker: name must be a string")
			assert(type(callback) == "function", "CreateColorPicker '" .. name .. "': callback must be a function")

			-- Sanitise default colour; fall back gracefully if nil or invalid
			if typeof(default) ~= "Color3" then
				default = Color3.fromRGB(255, 255, 255)
			end
			default = ClampColor(default)

			local base, lbl = CreateElementBase(name, ScrollFrame, 46)
			local pickerOpen = false

			local h, s, v = default:ToHSV()
			-- Clamp each component defensively
			h = math.clamp(h, 0, 1)
			s = math.clamp(s, 0, 1)
			v = math.clamp(v, 0, 1)
			local currentColor = default

			local swatch = Instance.new("TextButton")
			swatch.Size = UDim2.new(0, 36, 0, 28)
			swatch.Position = UDim2.new(1, -52, 0.5, -14)
			swatch.BackgroundColor3 = default
			swatch.Text = ""
			swatch.Parent = base
			RoundFrame(swatch, 6)
			Stroke(swatch, T.InputBorder)

			-- Expandable picker panel
			local panel = Instance.new("Frame")
			panel.Size = UDim2.new(0, 200, 0, 0)
			panel.Position = UDim2.new(1, -216, 0, 50)
			panel.BackgroundColor3 = T.Dropdown
			panel.BorderSizePixel = 0
			panel.Visible = false
			panel.ClipsDescendants = true
			panel.ZIndex = 30
			panel.Parent = base
			RoundFrame(panel, 6)
			Stroke(panel, T.Border)

			-- Hue bar
			local hueBar = Instance.new("Frame")
			hueBar.Size = UDim2.new(1, -16, 0, 14)
			hueBar.Position = UDim2.new(0, 8, 0, 8)
			hueBar.BorderSizePixel = 0
			hueBar.ZIndex = 31
			hueBar.Parent = panel
			RoundFrame(hueBar, 4)

			local hueGrad = Instance.new("UIGradient")
			hueGrad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,    1, 1)),
				ColorSequenceKeypoint.new(0.17, Color3.fromHSV(0.17, 1, 1)),
				ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33, 1, 1)),
				ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5,  1, 1)),
				ColorSequenceKeypoint.new(0.67, Color3.fromHSV(0.67, 1, 1)),
				ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83, 1, 1)),
				ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,    1, 1)),
			})
			hueGrad.Parent = hueBar

			local hueHit = Instance.new("TextButton")
			hueHit.Size = UDim2.new(1, 0, 1, 0)
			hueHit.BackgroundTransparency = 1
			hueHit.Text = ""
			hueHit.ZIndex = 32
			hueHit.Parent = hueBar

			-- Brightness/value bar
			local valBar = Instance.new("Frame")
			valBar.Size = UDim2.new(1, -16, 0, 14)
			valBar.Position = UDim2.new(0, 8, 0, 30)
			valBar.ZIndex = 31
			valBar.BorderSizePixel = 0
			valBar.Parent = panel
			RoundFrame(valBar, 4)

			local valGrad = Instance.new("UIGradient")
			valGrad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
				ColorSequenceKeypoint.new(1, Color3.fromHSV(h, 1, 1)),
			})
			valGrad.Parent = valBar

			local valHit = Instance.new("TextButton")
			valHit.Size = UDim2.new(1, 0, 1, 0)
			valHit.BackgroundTransparency = 1
			valHit.Text = ""
			valHit.ZIndex = 32
			valHit.Parent = valBar

			local function ApplyColor()
				-- Always clamp before constructing to prevent invalid HSV
				h = math.clamp(h, 0, 1)
				s = math.clamp(s, 0, 1)
				v = math.clamp(v, 0, 1)
				currentColor = Color3.fromHSV(h, s, v)
				swatch.BackgroundColor3 = currentColor
				valGrad.Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
					ColorSequenceKeypoint.new(1, Color3.fromHSV(h, 1, 1)),
				})
				local ok2, err = pcall(callback, currentColor)
				if not ok2 then
					warn("GhostLib ColorPicker '" .. name .. "' callback error: " .. tostring(err))
				end
			end

			hueHit.InputBegan:Connect(function(inp)
				if inp.UserInputType == Enum.UserInputType.MouseButton1 then
					local barW = hueBar.AbsoluteSize.X
					if barW <= 0 then return end
					h = math.clamp((UserInputService:GetMouseLocation().X - hueBar.AbsolutePosition.X) / barW, 0, 1)
					s = 1
					ApplyColor()
				end
			end)

			valHit.InputBegan:Connect(function(inp)
				if inp.UserInputType == Enum.UserInputType.MouseButton1 then
					local barW = valBar.AbsoluteSize.X
					if barW <= 0 then return end
					v = math.clamp((UserInputService:GetMouseLocation().X - valBar.AbsolutePosition.X) / barW, 0, 1)
					ApplyColor()
				end
			end)

			swatch.MouseButton1Click:Connect(function()
				pickerOpen = not pickerOpen
				if pickerOpen then
					panel.Visible = true
					Tween(panel, C.TWEEN_CUBIC, {Size = UDim2.new(0, 200, 0, 54)}):Play()
					Tween(base,  C.TWEEN_CUBIC, {Size = UDim2.new(1, 0, 0, 106)}):Play()
				else
					local t = Tween(panel, C.TWEEN_MED, {Size = UDim2.new(0, 200, 0, 0)})
					t:Play()
					Tween(base, C.TWEEN_MED, {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT)}):Play()
					t.Completed:Once(function()
						if not pickerOpen then panel.Visible = false end
					end)
				end
			end)

			local api = {}
			function api:Set(color)
				assert(typeof(color) == "Color3", "ColorPicker:Set — expected Color3")
				color = ClampColor(color)
				h, s, v = color:ToHSV()
				currentColor = color
				swatch.BackgroundColor3 = color
			end
			function api:Get() return currentColor end
			return api
		end

		-- ── CONFIG SYSTEM ──────────────────────────────────────────────────
		--- Save / Load profile placeholder.  Connect the buttons to your own
		--- serialisation logic by replacing the click handlers or extending this.
		--- @param profileKey string?  Identifier for the config profile.
		function Tab:CreateConfigSystem(profileKey)
			profileKey = type(profileKey) == "string" and profileKey or "GhostConfig_Default"
			local base, lbl = CreateElementBase("Configuration Profiles", ScrollFrame, 60)
			lbl.Size = UDim2.new(1, -200, 1, 0)

			local saveBtn = Instance.new("TextButton")
			saveBtn.Size = UDim2.new(0, 80, 0, 28)
			saveBtn.Position = UDim2.new(1, -186, 0.5, -14)
			saveBtn.BackgroundColor3 = T.Accent
			saveBtn.FontFace = Font.new("rbxasset://fonts/families/Montserrat.json")
			saveBtn.Text = "Save"
			saveBtn.TextColor3 = T.AccentDark
			saveBtn.TextSize = 12
			saveBtn.Parent = base
			RoundFrame(saveBtn, 6)

			local loadBtn = Instance.new("TextButton")
			loadBtn.Size = UDim2.new(0, 80, 0, 28)
			loadBtn.Position = UDim2.new(1, -96, 0.5, -14)
			loadBtn.BackgroundColor3 = T.Input
			loadBtn.FontFace = Font.new("rbxasset://fonts/families/Montserrat.json")
			loadBtn.Text = "Load"
			loadBtn.TextColor3 = T.TextSecondary
			loadBtn.TextSize = 12
			loadBtn.Parent = base
			RoundFrame(loadBtn, 6)
			Stroke(loadBtn, T.InputBorder)

			saveBtn.MouseButton1Click:Connect(function()
				-- TODO: implement actual profile serialisation here.
				-- Example: writefile(profileKey .. ".json", HttpService:JSONEncode(state))
				Notify("Config '" .. profileKey .. "' saved!", "success", 2)
			end)

			loadBtn.MouseButton1Click:Connect(function()
				-- TODO: implement actual profile deserialisation here.
				Notify("Config '" .. profileKey .. "' loaded!", "info", 2)
			end)
		end

		return Tab
	end

	-- ── BOOT ────────────────────────────────────────────────────────────────

	if skipIntro then
		ShowMainFrame(MainFrame)
	else
		RunIntro(function()
			ShowMainFrame(MainFrame)
		end)
	end

	return Window
end

return GhostLib
