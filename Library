local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer

local Library = {
    Flags = {}, -- Stores the current value of all elements
    Folder = "MyScriptConfigs", -- The folder created in your workspace directory
    Ext = ".json"
}

-- Ensure config folder exists
if makefolder and not isfolder(Library.Folder) then
    makefolder(Library.Folder)
end

function Library:CreateWindow(titleText)
    -- [Insert the MainFrame, Sidebar, and ContentFrame setup from the previous response here]
    -- For brevity, assuming MainFrame and Sidebar are set up.
    
    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(1, -190, 1, -20)
    ContentContainer.Position = UDim2.new(0, 190, 0, 10)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame -- Assuming MainFrame is already created

    local Elements = {}
    local Tabs = {}
    local activeTab = nil

    -- Tab System
    function Elements:CreateTab(tabName)
        -- Sidebar Button for the Tab
        local TabButton = Instance.new("TextButton")
        TabButton.Size = UDim2.new(1, -20, 0, 30)
        TabButton.Position = UDim2.new(0, 10, 0, 200 + (#Tabs * 35))
        TabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        TabButton.Text = tabName
        TabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        TabButton.Font = Enum.Font.Gotham
        TabButton.TextSize = 14
        TabButton.Parent = Sidebar -- Assuming Sidebar is already created
        Instance.new("UICorner", TabButton).CornerRadius = UDim.new(0, 4)

        -- Scrolling Frame for the Tab's Content
        local TabContent = Instance.new("ScrollingFrame")
        TabContent.Size = UDim2.new(1, 0, 1, 0)
        TabContent.BackgroundTransparency = 1
        TabContent.ScrollBarThickness = 4
        TabContent.Visible = false
        TabContent.Parent = ContentContainer
        
        local Layout = Instance.new("UIListLayout")
        Layout.Padding = UDim.new(0, 5)
        Layout.Parent = TabContent

        table.insert(Tabs, {Button = TabButton, Content = TabContent})

        TabButton.MouseButton1Click:Connect(function()
            for _, tab in ipairs(Tabs) do
                tab.Content.Visible = false
                tab.Button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            end
            TabContent.Visible = true
            TabButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        end)

        -- Initialize first tab
        if #Tabs == 1 then
            TabContent.Visible = true
            TabButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        end

        local TabElements = {}

        -- Modified Component Builders to support Flags
        function TabElements:CreateToggle(text, flag, callback)
            local state = false
            Library.Flags[flag] = state -- Register Flag

            local ToggleFrame = Instance.new("TextButton")
            -- [Insert Toggle UI creation from previous response]
            ToggleFrame.Parent = TabContent
            
            local function Update(newState)
                state = newState
                Library.Flags[flag] = state
                -- Update Indicator Color here
                if callback then callback(state) end
            end

            ToggleFrame.MouseButton1Click:Connect(function() Update(not state) end)

            -- Method to force update from config loader
            Library.Flags[flag .. "_Set"] = function(val) Update(val) end 
        end

        -- Add other elements (Sliders, Textboxes) with similar Flag logic...

        return TabElements
    end

    -- Configuration System Logic
    function Elements:CreateConfigSystem()
        local ConfigTab = self:CreateTab("Config")
        local configName = "default"

        -- Config Functions
        local function GetConfigs()
            local list = {}
            if listfiles then
                for _, file in ipairs(listfiles(Library.Folder)) do
                    if file:sub(-#Library.Ext) == Library.Ext then
                        local cleanName = file:gsub(Library.Folder .. "\\", ""):gsub(Library.Folder .. "/", ""):gsub(Library.Ext, "")
                        table.insert(list, cleanName)
                    end
                end
            end
            return list
        end

        local function SaveConfig(name)
            if writefile then
                local data = HttpService:JSONEncode(Library.Flags)
                writefile(Library.Folder .. "/" .. name .. Library.Ext, data)
            end
        end

        local function LoadConfig(name)
            local path = Library.Folder .. "/" .. name .. Library.Ext
            if isfile and isfile(path) and readfile then
                local success, decoded = pcall(function()
                    return HttpService:JSONDecode(readfile(path))
                end)
                if success and type(decoded) == "table" then
                    for flag, value in pairs(decoded) do
                        if Library.Flags[flag .. "_Set"] then
                            Library.Flags[flag .. "_Set"](value)
                        end
                    end
                end
            end
        end

        local function DeleteConfig(name)
            local path = Library.Folder .. "/" .. name .. Library.Ext
            if isfile and isfile(path) and delfile then
                delfile(path)
            end
        end

        local function SetAutoload(name)
            if writefile then
                writefile(Library.Folder .. "/autoload.txt", name)
            end
        end

        -- Config UI Elements
        ConfigTab:CreateTextbox("Config Name", "Enter name...", function(val)
            configName = val
        end)

        ConfigTab:CreateButton("Save Config", function()
            if configName ~= "" then SaveConfig(configName) end
        end)

        ConfigTab:CreateButton("Load Config", function()
            if configName ~= "" then LoadConfig(configName) end
        end)

        ConfigTab:CreateButton("Delete Config", function()
            if configName ~= "" then DeleteConfig(configName) end
        end)

        ConfigTab:CreateButton("Set as Autoload", function()
            if configName ~= "" then SetAutoload(configName) end
        end)

        -- Handle Autoload on script execution
        task.spawn(function()
            local autoPath = Library.Folder .. "/autoload.txt"
            if isfile and isfile(autoPath) and readfile then
                local autoName = readfile(autoPath)
                if autoName and autoName ~= "" then
                    LoadConfig(autoName)
                end
            end
        end)
    end

    return Elements
end

return Library
