    local GameVal    = StatCard("PLACE ID",        "⬡", 1, 1)

    GameVal.Text     = tostring(game.PlaceId)
    GameVal.TextSize = 13

    -- live stats update
    RunService.Heartbeat:Connect(function()
        local fps  = math.floor(1 / RunService.Heartbeat:Wait() * 10 + 0.5) / 10
        local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
        FpsVal.Text  = tostring(math.floor(fps))
