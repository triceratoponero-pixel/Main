		-- ── TOGGLE ─────────────────────────────────────────────────────────
		--- Boolean toggle switch.
		--- @param name     string
		--- @param default  boolean
		--- @param callback function(enabled: boolean)
		--- @return {Set:function, Get:function}
		function Tab:CreateToggle(name, default, callback)
			assert(type(name)     == "string",   "CreateToggle: name must be a string")
			assert(type(callback) == "function", "CreateToggle '" .. name .. "': callback must be a function")
			local enabled = default == true
			local base, lbl = CreateElementBase(name, ScrollFrame)

			local track = Instance.new("TextButton")
			track.Size = UDim2.new(0, 44, 0, 22)
			track.Position = UDim2.new(1, -60, 0.5, -11)
			track.BackgroundColor3 = enabled and T.ToggleOn or T.ToggleOff
			track.Text = ""
			track.Parent = base
			RoundFrame(track, 999)

			local circle = Instance.new("Frame")
			circle.Size = UDim2.new(0, 16, 0, 16)
			circle.Position = enabled and UDim2.new(1,-20,0.5,-8) or UDim2.new(0,4,0.5,-8)
			circle.BackgroundColor3 = enabled and T.CircleOn or T.CircleOff
			circle.Parent = track
			RoundFrame(circle, 999)

			track.MouseEnter:Connect(function()
				Tween(base, C.TWEEN_FAST, {BackgroundColor3 = T.ElementHover}):Play()
			end)
			track.MouseLeave:Connect(function()
				Tween(base, C.TWEEN_FAST, {BackgroundColor3 = T.Element}):Play()
			end)

			track.MouseButton1Click:Connect(function()
				enabled = not enabled
				Tween(circle, C.TWEEN_BACK, {
					Position         = enabled and UDim2.new(1,-20,0.5,-8) or UDim2.new(0,4,0.5,-8),
					BackgroundColor3 = enabled and T.CircleOn or T.CircleOff,
				}):Play()
				Tween(track, C.TWEEN_FAST, {
					BackgroundColor3 = enabled and T.ToggleOn or T.ToggleOff,
				}):Play()
				-- Tactile press squish
				Tween(track, TweenInfo.new(0.06), {Size = UDim2.new(0, 40, 0, 20)}):Play()
				task.delay(0.06, function()
					Tween(track, C.TWEEN_BACK, {Size = UDim2.new(0, 44, 0, 22)}):Play()
				end)
				-- Safely call callback and report errors without crashing the library
				local ok2, err = pcall(callback, enabled)
				if not ok2 then
					warn("GhostLib Toggle '" .. name .. "' callback error: " .. tostring(err))
				end
			end)

			local api = {}
			function api:Set(val)
				enabled = val == true
				circle.Position         = enabled and UDim2.new(1,-20,0.5,-8) or UDim2.new(0,4,0.5,-8)
				circle.BackgroundColor3 = enabled and T.CircleOn  or T.CircleOff
				track.BackgroundColor3  = enabled and T.ToggleOn  or T.ToggleOff
			end
			function api:Get() return enabled end
			return api
		end

