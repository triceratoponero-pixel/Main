    AvatarContainer.ZIndex           = 4
    AvatarContainer.Parent           = tabFrame
    Corner(AvatarContainer, 39)
    local avatarStroke = Stroke(AvatarContainer, Theme.Accent, 2)

    -- animated ring color
    task.spawn(function()
        while AvatarContainer.Parent do
            Tween(avatarStroke, {Color = Theme.AccentHover}, 1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(1.25)
            Tween(avatarStroke, {Color = Theme.Accent}, 1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(1.25)
        end
    end)

