-- ── AddColorpicker ────────────────────────────────────────────────
function SectionAPI:AddColorpicker(config)
    config = config or {}
    local label    = config.Title or config.Name or "Color"
    local default  = config.Default or Color3.fromRGB(99, 102, 241)
    local callback = config.Callback or function() end

    local row = MakeRow(self, 36)
    local color = default
    local open = false

    local lbl = Instance.new("TextLabel")
    lbl.Size                   = UDim2.new(1, -60, 1, 0)
    lbl.Position               = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = label
    lbl.TextColor3             = Theme.TextPrimary
    lbl.TextSize               = 13
    lbl.Font                   = Enum.Font.Gotham
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.ZIndex                 = 6
    lbl.Parent                 = row

    local swatch = Instance.new("TextButton")
    swatch.Size             = UDim2.new(0, 44, 0, 24)
    swatch.Position         = UDim2.new(1, -50, 0.5, -12)
    swatch.BackgroundColor3 = color
    swatch.Text             = ""
    swatch.BorderSizePixel  = 0
    swatch.ZIndex           = 6
    swatch.Parent           = row
    Corner(swatch, 6)
    Stroke(swatch, Theme.Border, 1)

    -- hue slider picker
    local picker = Instance.new("Frame")
    picker.Size             = UDim2.new(1, -12, 0, 100)
    picker.Position         = UDim2.new(0, 6, 1, 2)
    picker.BackgroundColor3 = Theme.Surface
    picker.BorderSizePixel  = 0
    picker.Visible          = false
    picker.ZIndex           = 15
    picker.Parent           = row
    Corner(picker, 8)
    Stroke(picker, Theme.Border, 1)

    -- hue gradient bar
    local hueBar = Instance.new("Frame")
    hueBar.Size             = UDim2.new(1, -12, 0, 16)
    hueBar.Position         = UDim2.new(0, 6, 0, 8)
    hueBar.BackgroundColor3 = Color3.fromRGB(255,255,255)
    hueBar.BorderSizePixel  = 0
    hueBar.ZIndex           = 16
    hueBar.Parent           = picker
    Corner(hueBar, 4)

    local hueGrad = Instance.new("UIGradient")
    hueGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   Color3.fromHSV(0, 1, 1)),
        ColorSequenceKeypoint.new(0.17, Color3.fromHSV(0.17, 1, 1)),
        ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33, 1, 1)),
        ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5, 1, 1)),
        ColorSequenceKeypoint.new(0.67, Color3.fromHSV(0.67, 1, 1)),
        ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83, 1, 1)),
        ColorSequenceKeypoint.new(1,    Color3.fromHSV(1, 1, 1)),
    })
    hueGrad.Parent = hueBar

    local hueH, hueS, hueV = Color3.toHSV(color)
    local hueThumb = Instance.new("Frame")
    hueThumb.Size             = UDim2.new(0, 10, 1, 2)
    hueThumb.Position         = UDim2.new(hueH, -5, 0, -1)
    hueThumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
    hueThumb.BorderSizePixel  = 0
    hueThumb.ZIndex           = 17
    hueThumb.Parent           = hueBar
    Corner(hueThumb, 3)

    -- preset swatches
    local presets = {
        Color3.fromRGB(99, 102, 241),
        Color3.fromRGB(52, 211, 153),
        Color3.fromRGB(251, 191, 36),
        Color3.fromRGB(248, 113, 113),
        Color3.fromRGB(167, 139, 250),
        Color3.fromRGB(56, 189, 248),
        Color3.fromRGB(255,255,255),
        Color3.fromRGB(60,60,80),
    }

    for i, pclr in ipairs(presets) do
        local ps = Instance.new("TextButton")
        ps.Size             = UDim2.new(0, 24, 0, 24)
        ps.Position         = UDim2.new(0, 6 + (i-1)*28, 0, 34)
        ps.BackgroundColor3 = pclr
        ps.Text             = ""
        ps.BorderSizePixel  = 0
        ps.ZIndex           = 16
        ps.Parent           = picker
        Corner(ps, 5)

        ps.MouseButton1Click:Connect(function()
            color = pclr
            Tween(swatch, {BackgroundColor3 = color}, 0.1)
            local h = Color3.toHSV(color)
            Tween(hueThumb, {Position = UDim2.new(h, -5, 0, -1)}, 0.1)
            callback(color)
        end)
    end

    -- hue bar drag
    local hDrag = false
    hueBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            hDrag = true
            local rel = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
            color = Color3.fromHSV(rel, 1, 1)
            hueThumb.Position = UDim2.new(rel, -5, 0, -1)
            Tween(swatch, {BackgroundColor3 = color}, 0.05)
            callback(color)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then hDrag = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if hDrag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
            color = Color3.fromHSV(rel, 1, 1)
            hueThumb.Position = UDim2.new(rel, -5, 0, -1)
            Tween(swatch, {BackgroundColor3 = color}, 0.05)
            callback(color)
        end
    end)

    swatch.MouseButton1Click:Connect(function()
        open = not open
        picker.Visible = open
    end)

    return {
        Set = function(_, c)
            color = c
            Tween(swatch, {BackgroundColor3 = c}, 0.1)
            callback(c)
        end,
        Get = function(_) return color end,
    }
end

