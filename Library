-- ║  MakeTab()
-- ══════════════════════════════════════════════════════════════════
function Nova:MakeTab(config)
    config = config or {}
    local label   = config.Title or config.Name or "Tab"
    local icon    = config.Icon  or ""
    local display = (icon ~= "" and icon .. "  " or "") .. label

    local order     = #self.Tabs + 2
    local _, tabFrame = self:_CreateTabButton(display, order)

    local tab = {
        Frame = tabFrame,
        _sections = {},
    }

    for k, v in pairs(TabAPI) do
        tab[k] = v
    end

    table.insert(self.Tabs, tab)
    return tab
end

-- ── internal: create tab button + frame pair ──────────────────────
function Nova:_CreateTabButton(label, order)
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size             = UDim2.new(0, 0, 1, 0)
    tabBtn.AutomaticSize    = Enum.AutomaticSize.X
    tabBtn.BackgroundColor3 = Theme.TabInactive
    tabBtn.Text             = ""
    tabBtn.BorderSizePixel  = 0
    tabBtn.LayoutOrder      = order
    tabBtn.ZIndex           = 6
    tabBtn.Parent           = self.TabBar
    Corner(tabBtn, 6)
    Padding(tabBtn, 0, 12, 0, 12)

    local tabLabel = Instance.new("TextLabel")
    tabLabel.Size                   = UDim2.new(1, 0, 1, 0)
    tabLabel.BackgroundTransparency = 1
    tabLabel.Text                   = label
    tabLabel.TextColor3             = Theme.TextSecondary
    tabLabel.TextSize               = 12
    tabLabel.Font                   = Enum.Font.GothamSemibold
    tabLabel.ZIndex                 = 7
    tabLabel.Parent                 = tabBtn

    -- tab content frame
    local tabFrame = Instance.new("ScrollingFrame")
    tabFrame.Size                = UDim2.new(1, 0, 1, 0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.BorderSizePixel     = 0
    tabFrame.ScrollBarThickness  = 3
    tabFrame.ScrollBarImageColor3 = Theme.ScrollBar
    tabFrame.CanvasSize          = UDim2.new(0, 0, 0, 0)
    tabFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tabFrame.Visible             = false
    tabFrame.ZIndex              = 3
    tabFrame.Parent              = self.ContentArea

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding   = UDim.new(0, 6)
    listLayout.Parent    = tabFrame
    Padding(tabFrame, 10, 10, 10, 10)

    -- activate on click
    tabBtn.MouseButton1Click:Connect(function()
        self:_SelectTab(tabBtn, tabLabel, tabFrame)
    end)

    -- auto-select first tab
    if #self.Tabs == 0 and order == 1 then
        self:_SelectTab(tabBtn, tabLabel, tabFrame)
    end

    return tabBtn, tabFrame
end

function Nova:_SelectTab(btn, lbl, frame)
    -- hide all
    for _, f in ipairs(self.ContentArea:GetChildren()) do
        if f:IsA("ScrollingFrame") then
            f.Visible = false
        end
    end
    for _, b in ipairs(self.TabBar:GetChildren()) do
        if b:IsA("TextButton") then
            Tween(b, {BackgroundColor3 = Theme.TabInactive}, 0.12)
            local l = b:FindFirstChildOfClass("TextLabel")
            if l then Tween(l, {TextColor3 = Theme.TextSecondary}, 0.12) end
        end
    end
    frame.Visible = true
    Tween(btn, {BackgroundColor3 = Theme.TabActive}, 0.12)
    Tween(lbl, {TextColor3 = Theme.TextPrimary}, 0.12)
end

-- ══════════════════════════════════════════════════════════════════
-- ║  Tab API  –  methods added to every tab object
-- ══════════════════════════════════════════════════════════════════
TabAPI = {}

-- ── AddSection ────────────────────────────────────────────────────
function TabAPI:AddSection(config)
    config = config or {}
    local title  = config.Title or config.Name or ""

    local wrapper = Instance.new("Frame")
    wrapper.Size             = UDim2.new(1, 0, 0, 0)
    wrapper.AutomaticSize    = Enum.AutomaticSize.Y
    wrapper.BackgroundColor3 = Theme.Surface
    wrapper.BorderSizePixel  = 0
    wrapper.LayoutOrder      = #self.Frame:GetChildren()
    wrapper.ZIndex           = 3
    wrapper.Parent           = self.Frame
    Corner(wrapper, 10)
    Stroke(wrapper, Theme.Border, 1)

    if title ~= "" then
        local header = Instance.new("Frame")
        header.Size             = UDim2.new(1, 0, 0, 32)
        header.BackgroundColor3 = Theme.TitleBar
        header.BorderSizePixel  = 0
        header.ZIndex           = 4
        header.Parent           = wrapper
        Corner(header, 10)

        local headerFill = Instance.new("Frame")
        headerFill.Size             = UDim2.new(1, 0, 0, 10)
        headerFill.Position         = UDim2.new(0, 0, 1, -10)
        headerFill.BackgroundColor3 = Theme.TitleBar
        headerFill.BorderSizePixel  = 0
        headerFill.ZIndex           = 3
        headerFill.Parent           = header

        local titleL = Instance.new("TextLabel")
        titleL.Size                   = UDim2.new(1, -12, 1, 0)
        titleL.Position               = UDim2.new(0, 12, 0, 0)
        titleL.BackgroundTransparency = 1
        titleL.Text                   = title
        titleL.TextColor3             = Theme.TextSecondary
        titleL.TextSize               = 11
        titleL.Font                   = Enum.Font.GothamBold
        titleL.TextXAlignment         = Enum.TextXAlignment.Left
        titleL.ZIndex                 = 5
        titleL.Parent                 = header

        -- content inside section
        local content = Instance.new("Frame")
        content.Name           = "SectionContent"
        content.Size           = UDim2.new(1, 0, 0, 0)
        content.Position       = UDim2.new(0, 0, 0, 32)
        content.AutomaticSize  = Enum.AutomaticSize.Y
        content.BackgroundTransparency = 1
        content.BorderSizePixel = 0
        content.ZIndex          = 4
        content.Parent          = wrapper

        local cl = Instance.new("UIListLayout")
        cl.SortOrder = Enum.SortOrder.LayoutOrder
        cl.Padding   = UDim.new(0, 4)
        cl.Parent    = content
        Padding(content, 6, 8, 8, 8)

        local section = setmetatable({Frame = content, _order = 0}, {__index = SectionAPI})
        return section
    else
        local content = Instance.new("Frame")
        content.Name           = "SectionContent"
        content.Size           = UDim2.new(1, 0, 0, 0)
        content.AutomaticSize  = Enum.AutomaticSize.Y
        content.BackgroundTransparency = 1
        content.BorderSizePixel = 0
        content.ZIndex          = 4
        content.Parent          = wrapper

        local cl = Instance.new("UIListLayout")
        cl.SortOrder = Enum.SortOrder.LayoutOrder
        cl.Padding   = UDim.new(0, 4)
        cl.Parent    = content
        Padding(content, 8, 8, 8, 8)

        local section = setmetatable({Frame = content, _order = 0}, {__index = SectionAPI})
        return section
    end
end

-- ══════════════════════════════════════════════════════════════════
-- ║  Section / Component API
-- ══════════════════════════════════════════════════════════════════
SectionAPI = {}

local function NextOrder(section)
    section._order = section._order + 1
    return section._order
end

