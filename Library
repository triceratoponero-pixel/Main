-- ║  Status Tab
-- ══════════════════════════════════════════════════════════════════
function Nova:_BuildStatusTab()
    local tabBtn, tabFrame = self:_CreateTabButton("⬡  Status", 1)

    -- player avatar circle
    local AvatarContainer = Instance.new("Frame")
    AvatarContainer.Size             = UDim2.new(0, 80, 0, 80)
    AvatarContainer.Position         = UDim2.new(0.5, -40, 0, 18)
    AvatarContainer.BackgroundColor3 = Theme.Surface
    AvatarContainer.BorderSizePixel  = 0
    AvatarContainer.ZIndex           = 4
    AvatarContainer.Parent           = tabFrame
    Corner(AvatarContainer, 40)
    Stroke(AvatarContainer, Theme.Accent, 2)

    local AvatarImg = Instance.new("ImageLabel")
    AvatarImg.Size             = UDim2.new(1, -4, 1, -4)
    AvatarImg.Position         = UDim2.new(0, 2, 0, 2)
    AvatarImg.BackgroundColor3 = Theme.Surface
    AvatarImg.Image            = ""
    AvatarImg.ZIndex           = 5
    AvatarImg.Parent           = AvatarContainer
    Corner(AvatarImg, 36)

    -- load avatar
    task.spawn(function()
        local userId = LocalPlayer.UserId
        local thumbType = Enum.ThumbnailType.HeadShot
        local thumbSize = Enum.ThumbnailSize.Size420x420
        local content, isReady = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)
        AvatarImg.Image = content
    end)

    -- player name
    local NameLabel = Instance.new("TextLabel")
    NameLabel.Size                   = UDim2.new(1, -20, 0, 22)
    NameLabel.Position               = UDim2.new(0, 10, 0, 104)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Text                   = LocalPlayer.DisplayName
    NameLabel.TextColor3             = Theme.TextPrimary
    NameLabel.TextSize               = 15
    NameLabel.Font                   = Enum.Font.GothamBold
    NameLabel.ZIndex                 = 4
    NameLabel.Parent                 = tabFrame

    local UsernameLabel = Instance.new("TextLabel")
    UsernameLabel.Size                   = UDim2.new(1, -20, 0, 16)
    UsernameLabel.Position               = UDim2.new(0, 10, 0, 124)
    UsernameLabel.BackgroundTransparency = 1
    UsernameLabel.Text                   = "@" .. LocalPlayer.Name
    UsernameLabel.TextColor3             = Theme.TextSecondary
    UsernameLabel.TextSize               = 12
    UsernameLabel.Font                   = Enum.Font.Gotham
    UsernameLabel.ZIndex                 = 4
    UsernameLabel.Parent                 = tabFrame

    -- stats grid
    local function StatCard(label, icon, xIdx, yIdx)
        local card = Instance.new("Frame")
        card.Size             = UDim2.new(0, 150, 0, 68)
        card.Position         = UDim2.new(0, 10 + xIdx * 158, 0, 155 + yIdx * 76)
        card.BackgroundColor3 = Theme.Surface
        card.BorderSizePixel  = 0
        card.ZIndex           = 4
        card.Parent           = tabFrame
        Corner(card, 10)
        Stroke(card, Theme.Border, 1)

        local iconL = Instance.new("TextLabel")
        iconL.Size                   = UDim2.new(0, 28, 0, 28)
        iconL.Position               = UDim2.new(0, 10, 0, 8)
        iconL.BackgroundTransparency = 1
        iconL.Text                   = icon
        iconL.TextSize               = 18
        iconL.Font                   = Enum.Font.GothamBold
        iconL.TextColor3             = Theme.Accent
        iconL.ZIndex                 = 5
        iconL.Parent                 = card

        local lbl = Instance.new("TextLabel")
        lbl.Size                   = UDim2.new(1, -10, 0, 14)
        lbl.Position               = UDim2.new(0, 10, 0, 36)
        lbl.BackgroundTransparency = 1
        lbl.Text                   = label
        lbl.TextColor3             = Theme.TextSecondary
        lbl.TextSize               = 10
        lbl.Font                   = Enum.Font.Gotham
        lbl.TextXAlignment         = Enum.TextXAlignment.Left
        lbl.ZIndex                 = 5
        lbl.Parent                 = card

        local val = Instance.new("TextLabel")
        val.Size                   = UDim2.new(1, -10, 0, 20)
        val.Position               = UDim2.new(0, 10, 0, 14)
        val.BackgroundTransparency = 1
        val.Text                   = "—"
        val.TextColor3             = Theme.TextPrimary
        val.TextSize               = 18
        val.Font                   = Enum.Font.GothamBold
        val.TextXAlignment         = Enum.TextXAlignment.Left
        val.ZIndex                 = 5
        val.Parent                 = card

        return val
