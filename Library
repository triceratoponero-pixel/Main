                    Dropdown.Toggled = not Dropdown.Toggled
                    TweenService:Create(DropdownFrame.F.Ico, TweenInfo.new(0.25, Enum.EasingStyle.Quint), { Rotation = Dropdown.Toggled and 180 or 0 }):Play()
                    local ElementsCount = math.clamp(#DropdownConfig.Options, 1, MaxElements)
                    local TargetSize = Dropdown.Toggled and UDim2.new(1, 0, 0, 38 + (ElementsCount * 28) + 4) or UDim2.new(1, 0, 0, 38)
                    DropdownContainer.Visible = Dropdown.Toggled
                    TweenService:Create(DropdownFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quint), { Size = TargetSize }):Play()
                end
                
                AddConnection(Click.MouseButton1Click, function()
                    ToggleDropdown()
                    pcall(function()
                        local SoundService = game:GetService("SoundService")
                        local sound = Instance.new("Sound", SoundService)
                        sound.SoundId = "rbxassetid://6895079853"
                        sound.Volume = 1
                        sound:Play()
                        game:GetService("Debris"):AddItem(sound, 3)
                    end)
                end)
                
                function Dropdown:Refresh(OptionsArray, ClearSelection)
                    DropdownConfig.Options = OptionsArray
                    for _, btn in pairs(Buttons) do btn:Destroy() end
                    table.clear(Buttons)
                    if ClearSelection then Dropdown:Set(DropdownConfig.Multi and {} or "") end
                    
                    for _, name in ipairs(DropdownConfig.Options) do
                        local OptionBtn = AddThemeObject(SetProps(SetChildren(MakeElement("Button"), {
                            MakeElement("Corner", 0, 6),
                            AddThemeObject(SetProps(MakeElement("Label", name, 13, 0.4), { Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -8, 1, 0), Name = "Title", Font = Enum.Font.FredokaOne }), "Text")
                        }), { Parent = DropdownContainer, Size = UDim2.new(1, 0, 0, 28), BackgroundTransparency = 0.8, ClipsDescendants = true }), "Divider")
                        
                        AddConnection(OptionBtn.MouseButton1Click, function()
                            Dropdown:Set(name)
                            pcall(function()
                                local SoundService = game:GetService("SoundService")
                                local sound = Instance.new("Sound", SoundService)
                                sound.SoundId = "rbxassetid://6895079853"
                                sound.Volume = 1
                                sound:Play()
                                game:GetService("Debris"):AddItem(sound, 3)
                            end)
                        end)
                        Buttons[name] = OptionBtn
                    end
                end
                
                function Dropdown:Set(Value)
                    if DropdownConfig.Multi then
                        if type(Value) == "table" then Dropdown.Value = Value else
                            if table.find(Dropdown.Value, Value) then table.remove(Dropdown.Value, table.find(Dropdown.Value, Value)) else table.insert(Dropdown.Value, Value) end
                        end
                        local DisplayText = ""
                        for _, v in pairs(Buttons) do
                            if table.find(Dropdown.Value, v.Title.Text) then
                                v.BackgroundTransparency = 0.3; v.Title.TextTransparency = 0
                            else
                                v.BackgroundTransparency = 0.8; v.Title.TextTransparency = 0.4
                            end
                        end
                        for i, v in ipairs(Dropdown.Value) do DisplayText = DisplayText .. (i > 1 and ", " or "") .. v end
                        DropdownFrame.F.Selected.Text = DisplayText == "" and "None" or DisplayText
                    else
                        Dropdown.Value = Value
                        for _, v in pairs(Buttons) do
                            if v.Title.Text == Value then
                                v.BackgroundTransparency = 0.3; v.Title.TextTransparency = 0
                            else
                                v.BackgroundTransparency = 0.8; v.Title.TextTransparency = 0.4
                            end
                        end
                        DropdownFrame.F.Selected.Text = Value == "" and "None" or Value
                    end
                    task.spawn(function() DropdownConfig.Callback(Dropdown.Value) end)
                end
                
                Dropdown:Refresh(DropdownConfig.Options, false)
                if DropdownConfig.Default then Dropdown:Set(DropdownConfig.Default) end
                if DropdownConfig.Flag then Nova.Flags[DropdownConfig.Flag] = Dropdown end
                return Dropdown
            end

