-- ── Utility ───────────────────────────────────────────────────────
local function Tween(obj, props, t, style, dir)
    local info = TweenInfo.new(
        t     or 0.18,
        style or Enum.EasingStyle.Quart,
        dir   or Enum.EasingDirection.Out
    )
    TweenService:Create(obj, info, props):Play()
end

local function TweenSpring(obj, props, t)
    Tween(obj, props, t or 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

local function Stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color     = color     or Theme.Border
    s.Thickness = thickness or 1
    s.Parent    = parent
    return s
end

local function Corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

local function Padding(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 6)
    p.PaddingRight  = UDim.new(0, right  or 6)
    p.PaddingBottom = UDim.new(0, bottom or 6)
    p.PaddingLeft   = UDim.new(0, left   or 6)
    p.Parent = parent
    return p
end

-- Animated hover: scale + color
local function HoverEffect(btn, normalColor, hoverColor)
    btn.MouseEnter:Connect(function()
        Tween(btn, {BackgroundColor3 = hoverColor}, 0.13)
    end)
    btn.MouseLeave:Connect(function()
        Tween(btn, {BackgroundColor3 = normalColor}, 0.13)
    end)
end

-- Click ripple: briefly shrink then spring back
local function ClickBounce(btn, callback)
    btn.MouseButton1Click:Connect(function()
        local orig = btn.Size
        Tween(btn, {Size = UDim2.new(orig.X.Scale, orig.X.Offset - 6, orig.Y.Scale, orig.Y.Offset - 4)}, 0.07)
        task.delay(0.08, function()
            TweenSpring(btn, {Size = orig}, 0.28)
        end)
        if callback then callback() end
    end)
end

local function MakeDraggable(frame, handle)
    local dragging, startPos, startFramePos = false, nil, nil
    handle = handle or frame

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging      = true
            startPos      = input.Position
            startFramePos = frame.Position
        end
    end)
    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - startPos
            frame.Position = UDim2.new(
                startFramePos.X.Scale, startFramePos.X.Offset + delta.X,
                startFramePos.Y.Scale, startFramePos.Y.Offset + delta.Y
            )
        end
    end)
end

-- Notification popup (top-right, auto-dismiss)
local function Notify(screenGui, message, color, duration)
    color    = color    or Theme.Accent
    duration = duration or 2.5

    local notif = Instance.new("Frame")
    notif.Size             = UDim2.new(0, 240, 0, 42)
    notif.Position         = UDim2.new(1, -250, 0, -60)
    notif.BackgroundColor3 = Theme.Surface
    notif.BorderSizePixel  = 0
    notif.ZIndex           = 200
    notif.Parent           = screenGui
    Corner(notif, 10)
    Stroke(notif, color, 1)

    local bar = Instance.new("Frame")
    bar.Size             = UDim2.new(0, 4, 1, -12)
    bar.Position         = UDim2.new(0, 6, 0, 6)
    bar.BackgroundColor3 = color
    bar.BorderSizePixel  = 0
    bar.ZIndex           = 201
    bar.Parent           = notif
    Corner(bar, 2)

    local lbl = Instance.new("TextLabel")
    lbl.Size                   = UDim2.new(1, -22, 1, 0)
    lbl.Position               = UDim2.new(0, 18, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = message
    lbl.TextColor3             = Theme.TextPrimary
    lbl.TextSize               = 12
    lbl.Font                   = Enum.Font.GothamSemibold
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.TextWrapped            = true
    lbl.ZIndex                 = 201
    lbl.Parent                 = notif

    -- slide in
    Tween(notif, {Position = UDim2.new(1, -250, 0, 14)}, 0.3, Enum.EasingStyle.Back)
    -- slide out after duration
    task.delay(duration, function()
        Tween(notif, {Position = UDim2.new(1, 260, 0, 14)}, 0.25, Enum.EasingStyle.Quart)
        task.delay(0.3, function() notif:Destroy() end)
    end)
end

