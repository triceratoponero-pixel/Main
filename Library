                                                CpConfig.Callback(CurrentColor)
                                        end
                                }
                        end

                        return CpFrame
                end

                table.insert(Window.Tabs, Tab)
                return Tab
        end

        local function _configPath(name)
                return WindowConfig.ConfigFolder .. "/configs/" .. name .. ".txt"
        end

        local function _ensureFolders()
                if not isfolder(WindowConfig.ConfigFolder) then makefolder(WindowConfig.ConfigFolder) end
                if not isfolder(WindowConfig.ConfigFolder .. "/configs") then makefolder(WindowConfig.ConfigFolder .. "/configs") end
        end

        local function _checkExecutor()
                return (writefile and readfile and isfile and isfolder and makefolder and listfiles)
        end

        local function _b64_encode(data)
                return HttpService:JSONEncode({raw = data})
        end

        local function _b64_decode(data)
                local ok, res = pcall(function()
                        return HttpService:JSONDecode(data).raw
                end)
                return ok and res or data
        end

        function Library:SaveConfig(name)
                if not name or name == "" then return false end
                if not _checkExecutor() then return false end
                local ok, err = pcall(function()
                        _ensureFolders()
                        local Data = {}
                        for i, v in pairs(Library.Flags) do
                                if v.Save then
                                        if v.Type == "Colorpicker" then
                                                Data[i] = PackColor(v.Value)
                                        else
                                                Data[i] = v.Value
                                        end
                                end
                        end
                        writefile(_configPath(name), HttpService:JSONEncode(Data))
                end)
                if not ok then
                        warn("Pacific SaveConfig Error:", err)
                        return false
                end
                return true
        end

        function Library:LoadConfig(name)
                if not name or name == "" then return false end
                if not _checkExecutor() then return false end
                local path = _configPath(name)
                if not isfile(path) then return false end
                local ok, content = pcall(readfile, path)
                if not ok then return false end
                LoadCfg(content)
                return true
        end

        function Library:DeleteConfig(name)
                if not name or name == "" then return false end
                if not _checkExecutor() then return false end
                local path = _configPath(name)
                if not isfile(path) then return false end
                if delfile then
                        pcall(delfile, path)
                        return true
                end
                return false
        end

        function Library:GetConfigId(name)
                if not name or name == "" then return "" end
                if not _checkExecutor() then return "" end
                local path = _configPath(name)
                if not isfile(path) then return "" end
                local ok, raw = pcall(readfile, path)
                if not ok then return "" end
                return _b64_encode(raw)
        end

        function Library:SaveConfigId(name, id)
                if not name or name == "" then return false end
                if not id or id == "" then return false end
                if not _checkExecutor() then return false end
                local ok, err = pcall(function()
                        _ensureFolders()
                        local raw = _b64_decode(id)
                        HttpService:JSONDecode(raw)
                        writefile(_configPath(name), raw)
                end)
                if not ok then
                        return false
                end
                return true
        end

        function Library:ListConfigs()
                if not _checkExecutor() then return {} end
                local list = {}
                local ok, files = pcall(listfiles, WindowConfig.ConfigFolder .. "/configs")
                if not ok or not files then return list end
                for _, file in ipairs(files) do
                        local n = file:match("([^/\\\.]+)%.txt$") or file:match("([^%\\]+)%.txt$")
                        if n then table.insert(list, n) end
                end
                return list
        end

        return Window
end

return Library
