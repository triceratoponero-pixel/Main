                    AddThemeObject(MakeElement("Stroke"), "Stroke"), SearchActual
                }), "Second")
                Create("UIGradient", { Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, Color3.fromRGB(28, 28, 28)), ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 20, 20)) }), Rotation = 90 }).Parent = SearchFrame
                
                local function getElementText(child)
                    for _, lbl in ipairs(child:GetDescendants()) do
                        if lbl:IsA("TextLabel") and (lbl.Name == "Content" or lbl.Name == "Title") then return lbl.Text or "" end
                    end
                    return ""
                end
                
                AddConnection(SearchActual:GetPropertyChangedSignal("Text"), function()
                    local query = string.lower(SearchActual.Text or "")
                    for _, child in ipairs(ItemParent:GetChildren()) do
                        if child ~= SearchFrame and (child:IsA("Frame") or child:IsA("TextButton")) then
                            if query == "" then child.Visible = true else
                                local txt = string.lower(getElementText(child))
                                child.Visible = txt ~= "" and string.find(txt, query, 1, true) ~= nil
                            end
                        end
                    end
                end)
                
                local SearchObj = {}
                function SearchObj:Set(text) SearchActual.Text = text or "" end
                function SearchObj:Clear() SearchActual.Text = "" end
                return SearchObj
            end

            -- 13. Config Persistence Section Layout Engine Component
            function ElementFunction:AddConfigSection(ConfigSectionConfig)
                ConfigSectionConfig = ConfigSectionConfig or {}
                local currentName = ""
                local selectedConfig = ""
                local currentId = ""
                local saveAsName = ""
                
                local function getList()
                    local list = Nova:ListConfigs() or {}
                    if #list == 0 then list = {"(no configs)"} end
                    return list
                end
                
                ElementFunction:AddTextbox({ Name = "New Config Name", Default = "", TextDisappear = false, Callback = function(text) currentName = text end })
                ElementFunction:AddButton({ Name = "Save Current Config", Callback = function()
                    if currentName == "" then Nova:MakeNotification({Name = "Config", Content = "Type a filename context first.", Time = 4}) return end
                    SaveCfg(currentName)
                end })
                
                local configDropdown = ElementFunction:AddDropdown({ Name = "Select Config File", Options = getList(), Default = "", Multi = false, Callback = function(val) selectedConfig = val end })
                
                ElementFunction:AddButton({ Name = "Load Config Template", Callback = function()
                    if selectedConfig == "" or selectedConfig == "(no configs)" then Nova:MakeNotification({Name = "Config", Content = "Pick a config file selection.", Time = 4}) return end
                    if _checkExecutor() then
                        local p = _configPath(selectedConfig)
                        if isfile(p) then LoadCfg(readfile(p)) end
                    end
                end })
                ElementFunction:AddButton({ Name = "Refresh Configurations List", Callback = function() configDropdown:Refresh(getList(), true) selectedConfig = "" end })
                ElementFunction:AddButton({ Name = "Auto-Load Selected", Callback = function()
                    if selectedConfig == "" or selectedConfig == "(no configs)" then Nova:MakeNotification({Name = "Config", Content = "Pick a config from the dropdown first.", Time = 4}) return end
                    Nova:AutoLoadConfig(selectedConfig)
                end })
                ElementFunction:AddButton({ Name = "Disable Auto-Load", Callback = function() Nova:UnAutoLoadConfig() end })
                ElementFunction:AddButton({ Name = "Share Selected (copy ID)", Callback = function()
                    if selectedConfig == "" or selectedConfig == "(no configs)" then Nova:MakeNotification({Name = "Config", Content = "Pick a config from the dropdown first.", Time = 4}) return end
                    Nova:ShareConfigId(selectedConfig)
                end })
                ElementFunction:AddTextbox({ Name = "Config ID", Default = "", TextDisappear = false, Callback = function(text) currentId = text end })
                ElementFunction:AddButton({ Name = "Use Config ID", Callback = function()
                    if currentId == "" then Nova:MakeNotification({Name = "Config", Content = "Paste a Config ID first.", Time = 4}) return end
                    Nova:UseConfigId(currentId)
                end })
                ElementFunction:AddTextbox({ Name = "Save ID As", Default = "", TextDisappear = false, Callback = function(text) saveAsName = text end })
                ElementFunction:AddButton({ Name = "Save Config from ID", Callback = function()
                    if saveAsName == "" or currentId == "" then Nova:MakeNotification({Name = "Config", Content = "Need both a Config ID and a 'Save As' name.", Time = 4}) return end
                    Nova:SaveConfigId(saveAsName, currentId)
                    configDropdown:Refresh(getList(), true)
                end })
                
                return {
                    SetName = function(_, n) currentName = n end, SetId = function(_, i) currentId = i end,
                    Refresh = function() configDropdown:Refresh(getList(), true) end, Dropdown = configDropdown
                }
            end

            return ElementFunction
        end

