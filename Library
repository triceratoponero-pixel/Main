## Example Usage

### Complete Script Example

```lua
local GhostLib = require(game.ReplicatedStorage:WaitForChild("library"))

-- Create window
local Window = GhostLib:CreateWindow({
    SkipIntro = false,
    IntroDuration = 4.0
})

-- Create tabs
local SettingsTab = Window:CreateTab("Settings", "⚙️")
local FeaturesTab = Window:CreateTab("Features", "✨")

-- Settings Tab
SettingsTab:CreateLabel("User Settings", "header")
SettingsTab:CreateDivider("Appearance")

local ThemeToggle = SettingsTab:CreateToggle("Dark Mode", true, function(enabled)
    print("Dark mode: " .. tostring(enabled))
end)

local VolumeSlider = SettingsTab:CreateSlider("Volume", 0, 100, 50, function(value)
    print("Volume set to: " .. value .. "%")
end)

SettingsTab:CreateDivider("Advanced")

local UsernameBox = SettingsTab:CreateTextBox("Username", "Enter username", function(text)
    print("Username: " .. text)
end)

-- Features Tab
FeaturesTab:CreateLabel("Feature Controls", "header")
FeaturesTab:CreateParagraph("About", "Enable various features and configure them.")

local GameDropdown = FeaturesTab:CreateDropdown("Select Game", {"BSS", "Driving Empire", "StreetLife"}, function(game)
    Window:Notify("Game selected: " .. game, "info", 2)
end)

local FeaturesMulti = FeaturesTab:CreateMultiDropdown(
    "Enable Features",
    {"ESP", "Aimbot", "Wallhack", "Speed Hack"},
    { CloseOnSelect = true },
    function(selected)
        print("Enabled: " .. table.concat(selected, ", "))
    end
)

local ColorPicker = FeaturesTab:CreateColorPicker("Accent Color", Color3.fromRGB(255, 255, 255), function(color)
    print("Color updated")
end)

FeaturesTab:CreateButton("Save Config", function()
    Window:Notify("Configuration saved!", "success", 2)
end)

-- Keybind
FeaturesTab:CreateKeybind("Toggle Menu", Enum.KeyCode.F5, function(key)
    Window:Notify("Keybind set to: " .. key.Name, "info", 2)
end)
```

