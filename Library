            function ElementFunction:AddSearch(SearchConfig)
                SearchConfig = SearchConfig or {}
                SearchConfig.Name = SearchConfig.Name or "Search Components..."
                local SearchActual = Create("TextBox", { Text = "", TextColor3 = Color3.fromRGB(240, 240, 240), Font = Enum.Font.FredokaOne, TextSize = 14, BackgroundTransparency = 1, Size = UDim2.new(1, -40, 1, 0), Position = UDim2.new(0, 12, 0, 0), PlaceholderText = SearchConfig.Name, PlaceholderColor3 = Color3.fromRGB(120, 120, 120) })
                
