function SectionAPI:AddColorpicker(config)
    config = config or {}
    local label    = config.Title or config.Name or "Color"
    local default  = config.Default or Color3.fromRGB(99,102,241)
    local callback = config.Callback or function() end
    local row = MakeRow(self, 36)
    local color, open = default, false

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-60,1,0) lbl.Position = UDim2.new(0,10,0,0)
    lbl.BackgroundTransparency = 1 lbl.Text = label
