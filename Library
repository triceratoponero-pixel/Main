function Nova:_BuildStatusTab()
    local _, tabFrame = self:_CreateTabButton("◈  Status", 1)

    -- avatar ring
    local AvatarContainer = Instance.new("Frame")
    AvatarContainer.Size             = UDim2.new(0, 78, 0, 78)
    AvatarContainer.Position         = UDim2.new(0.5, -39, 0, 14)
