end

--// CONFIG PERSISTENCE API

function Library:CreateConfig(name)
    if not self.SaveConfig then return end
    local path = self.Folder .. "\\" .. name .. ".json"
    local data = HttpService:JSONEncode(self.Flags)
    writefile(path, data)
end

function Library:UseConfig(name)
    if not self.SaveConfig then return end
    local path = self.Folder .. "\\" .. name .. ".json"
    if isfile(path) then
        local data = HttpService:JSONDecode(readfile(path))
        for flag, value in pairs(data) do
            self.Flags[flag] = value
            -- Note: In a full integration, you iterate through active element objects and call :Set(value)
        end
    end
end

function Library:DeleteConfig(name)
    local path = self.Folder .. "\\" .. name .. ".json"
    if isfile(path) then delfile(path) end
end

function Library:AutoLoadConfig(name)
    self:CreateConfig("autoload_ptr") -- Points to which config to load
end

function Library:UnAutoLoadConfig()
    self:DeleteConfig("autoload_ptr")
end

function Library:ShareConfigId(name) return "" end
function Library:UseConfigId(id) end
function Library:SaveConfigId(name, id) end
function Library:ListConfigs()
    local configs = {}
    for _, file in pairs(listfiles(self.Folder)) do
        table.insert(configs, file)
    end
    return configs
end

return Library
