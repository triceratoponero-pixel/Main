    -- online players (updates every 5 seconds)
    task.spawn(function()
        while task.wait(5) do
            PlayersVal.Text = tostring(#Players:GetPlayers())
        end
    end)
    PlayersVal.Text = tostring(#Players:GetPlayers())
end

