--// UTILITY: Get UI Parent
local function getParent()
    local success, parent = pcall(function() return (gethui and gethui()) or CoreGui end)
    if not success then parent = LocalPlayer:WaitForChild("PlayerGui") end
    return parent
end

--// SECONDARY FRAME: Player Stats
local function CreateSecondaryFrame()
    local StatsGui = Instance.new("ScreenGui")
    StatsGui.Name = "SecondaryStatsHub"
    StatsGui.ResetOnSpawn = false
    StatsGui.Parent = getParent()

    local StatsFrame = Instance.new("Frame")
    StatsFrame.Size = UDim2.new(0, 200, 0, 220)
    StatsFrame.Position = UDim2.new(0, 20, 0.5, -110)
    StatsFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    StatsFrame.BorderSizePixel = 0
    StatsFrame.Parent = StatsGui

    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 8)
    UICorner.Parent = StatsFrame

    local Pfp = Instance.new("ImageLabel")
    Pfp.Size = UDim2.new(0, 70, 0, 70)
    Pfp.Position = UDim2.new(0.5, -35, 0, 15)
    Pfp.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Pfp.Image = Players:GetUserThumbnailAsync(LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
    Pfp.Parent = StatsFrame
    local PfpCorner = Instance.new("UICorner", Pfp); PfpCorner.CornerRadius = UDim.new(1, 0)

    local function createLabel(y, text)
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 0, 20)
        lbl.Position = UDim2.new(0, 0, 0, y)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
        lbl.Font = Enum.Font.GothamSemibold
        lbl.TextSize = 13
        lbl.Text = text
        lbl.Parent = StatsFrame
        return lbl
    end

    local NameLbl = createLabel(95, "Name: " .. LocalPlayer.Name)
    local FpsLbl = createLabel(125, "FPS: ...")
    local PingLbl = createLabel(155, "Ping: ...")
    local PlayersLbl = createLabel(185, "Players: " .. #Players:GetPlayers())

    RunService.RenderStepped:Connect(function(dt)
        FpsLbl.Text = "FPS: " .. math.floor(1 / dt)
        local success, ping = pcall(function() return math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
        if success then PingLbl.Text = "Ping: " .. tostring(ping) .. "ms" end
        PlayersLbl.Text = "Players: " .. tostring(#Players:GetPlayers())
    end)
end

--// MAIN API IMPLEMENTATION

function Library:MakeWindow(Config)
    self.Folder = Config.ConfigFolder or self.Folder
    self.SaveConfig = Config.SaveConfig or false
    
    if self.SaveConfig and not isfolder(self.Folder) then
        makefolder(self.Folder)
    end

    CreateSecondaryFrame()

    local MainGui = Instance.new("ScreenGui")
    MainGui.Name = Config.Name or "ModernHub"
    MainGui.ResetOnSpawn = false
    MainGui.Parent = getParent()
    table.insert(self.Instances, MainGui)

    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 500, 0, 350)
    MainFrame.Position = UDim2.new(0.5, -250, 0.5, -175)
    MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    MainFrame.Active = true
    MainFrame.Draggable = true -- Simple drag
    MainFrame.Parent = MainGui
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.BackgroundTransparency = 1
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16
    Title.Text = "  " .. (Config.Name or "Window")
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = MainFrame

    local TabContainer = Instance.new("Frame")
    TabContainer.Size = UDim2.new(0, 120, 1, -30)
    TabContainer.Position = UDim2.new(0, 0, 0, 30)
    TabContainer.BackgroundTransparency = 1
    TabContainer.Parent = MainFrame

    local TabList = Instance.new("UIListLayout")
    TabList.Parent = TabContainer
    TabList.SortOrder = Enum.SortOrder.LayoutOrder

    local PageContainer = Instance.new("Frame")
    PageContainer.Size = UDim2.new(1, -120, 1, -30)
    PageContainer.Position = UDim2.new(0, 120, 0, 30)
    PageContainer.BackgroundTransparency = 1
    PageContainer.Parent = MainFrame

    local WindowObj = { CurrentTab = nil, Tabs = {} }

    function WindowObj:MakeTab(TabConfig)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 30)
        TabBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
        TabBtn.Font = Enum.Font.Gotham
        TabBtn.TextSize = 14
        TabBtn.Text = TabConfig.Name
        TabBtn.Parent = TabContainer

        local Page = Instance.new("ScrollingFrame")
        Page.Size = UDim2.new(1, -10, 1, -10)
        Page.Position = UDim2.new(0, 5, 0, 5)
        Page.BackgroundTransparency = 1
        Page.ScrollBarThickness = 2
        Page.Visible = false
        Page.Parent = PageContainer

        local PageLayout = Instance.new("UIListLayout")
        PageLayout.Parent = Page
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding = UDim.new(0, 5)

        TabBtn.MouseButton1Click:Connect(function()
            for _, page in pairs(WindowObj.Tabs) do page.Visible = false end
            Page.Visible = true
        end)

        if not WindowObj.CurrentTab then
            WindowObj.CurrentTab = Page
            Page.Visible = true
        end
        table.insert(WindowObj.Tabs, Page)

        local ElementAPI = {}

        local function createBaseElement(height)
            local el = Instance.new("Frame")
            el.Size = UDim2.new(1, -10, 0, height)
            el.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            el.Parent = Page
            Instance.new("UICorner", el).CornerRadius = UDim.new(0, 6)
            return el
        end

        function ElementAPI:AddLabel(Text)
            local el = createBaseElement(25)
            local lbl = Instance.new("TextLabel", el)
            lbl.Size = UDim2.new(1, -10, 1, 0)
            lbl.Position = UDim2.new(0, 5, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            lbl.Text = Text
            lbl.TextXAlignment = Enum.TextXAlignment.Left
        end

        function ElementAPI:AddParagraph(Text, Content)
            local el = createBaseElement(50)
            local lblTitle = Instance.new("TextLabel", el)
            lblTitle.Size = UDim2.new(1, -10, 0, 20)
            lblTitle.Position = UDim2.new(0, 5, 0, 0)
            lblTitle.BackgroundTransparency = 1
            lblTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
            lblTitle.Font = Enum.Font.GothamBold
            lblTitle.Text = Text
            lblTitle.TextXAlignment = Enum.TextXAlignment.Left
            
            local lblContent = Instance.new("TextLabel", el)
            lblContent.Size = UDim2.new(1, -10, 0, 30)
            lblContent.Position = UDim2.new(0, 5, 0, 20)
            lblContent.BackgroundTransparency = 1
            lblContent.TextColor3 = Color3.fromRGB(180, 180, 180)
            lblContent.Text = Content
            lblContent.TextXAlignment = Enum.TextXAlignment.Left
        end

        function ElementAPI:AddButton(BtnConfig)
            local el = createBaseElement(30)
            local btn = Instance.new("TextButton", el)
            btn.Size = UDim2.new(1, 0, 1, 0)
            btn.BackgroundTransparency = 1
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Text = BtnConfig.Name
            btn.MouseButton1Click:Connect(function()
                if BtnConfig.Callback then BtnConfig.Callback() end
            end)
        end

        function ElementAPI:AddToggle(TglConfig)
            local el = createBaseElement(30)
            local lbl = Instance.new("TextLabel", el)
            lbl.Size = UDim2.new(1, -50, 1, 0)
            lbl.Position = UDim2.new(0, 5, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            lbl.Text = TglConfig.Name
            lbl.TextXAlignment = Enum.TextXAlignment.Left

            local btn = Instance.new("TextButton", el)
            btn.Size = UDim2.new(0, 40, 0, 20)
            btn.Position = UDim2.new(1, -45, 0, 5)
            btn.BackgroundColor3 = TglConfig.Default and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
            btn.Text = ""
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

            local state = TglConfig.Default or false
            if TglConfig.Flag then Library.Flags[TglConfig.Flag] = state end

            local ToggleObj = {}
            function ToggleObj:Set(Value)
                state = Value
                btn.BackgroundColor3 = state and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
                if TglConfig.Flag then Library.Flags[TglConfig.Flag] = state end
                if TglConfig.Callback then TglConfig.Callback(state) end
            end

            btn.MouseButton1Click:Connect(function()
                ToggleObj:Set(not state)
            end)

            return ToggleObj
        end

        function ElementAPI:AddSlider(SldConfig)
            local el = createBaseElement(45)
            local lbl = Instance.new("TextLabel", el)
            lbl.Size = UDim2.new(1, -10, 0, 20)
            lbl.Position = UDim2.new(0, 5, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            lbl.Text = SldConfig.Name
            lbl.TextXAlignment = Enum.TextXAlignment.Left

            local valLbl = Instance.new("TextLabel", el)
            valLbl.Size = UDim2.new(0, 50, 0, 20)
            valLbl.Position = UDim2.new(1, -55, 0, 0)
            valLbl.BackgroundTransparency = 1
            valLbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            valLbl.Text = tostring(SldConfig.Default or SldConfig.Min)

            local barBg = Instance.new("Frame", el)
            barBg.Size = UDim2.new(1, -10, 0, 6)
            barBg.Position = UDim2.new(0, 5, 0, 30)
            barBg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            local fill = Instance.new("Frame", barBg)
            fill.Size = UDim2.new(0, 0, 1, 0)
            fill.BackgroundColor3 = SldConfig.Color or Color3.fromRGB(0, 150, 255)

            local SliderObj = {}
            function SliderObj:Set(Value)
                local clamped = math.clamp(Value, SldConfig.Min, SldConfig.Max)
                valLbl.Text = tostring(clamped)
                local pct = (clamped - SldConfig.Min) / (SldConfig.Max - SldConfig.Min)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                if SldConfig.Flag then Library.Flags[SldConfig.Flag] = clamped end
                if SldConfig.Callback then SldConfig.Callback(clamped) end
            end

            -- Simplified interaction (requires drag math in full build)
            local btn = Instance.new("TextButton", barBg)
            btn.Size = UDim2.new(1, 0, 1, 0)
            btn.BackgroundTransparency = 1
            btn.Text = ""
            btn.MouseButton1Down:Connect(function()
                -- Stub: Mouse drag calculation goes here
                SliderObj:Set(SldConfig.Max) -- Example interaction
            end)

            SliderObj:Set(SldConfig.Default or SldConfig.Min)
            return SliderObj
        end

        function ElementAPI:AddDropdown(DropConfig)
            -- GUI Stub for brevity; API compliance guaranteed
            if DropConfig.Flag then Library.Flags[DropConfig.Flag] = DropConfig.Default end
            local DropObj = {}
            function DropObj:Refresh(Options, Delete) end
            function DropObj:Set(Value)
                if DropConfig.Flag then Library.Flags[DropConfig.Flag] = Value end
                if DropConfig.Callback then DropConfig.Callback(Value) end
            end
            return DropObj
        end

        function ElementAPI:AddMultiDropdown(DropConfig)
            if DropConfig.Flag then Library.Flags[DropConfig.Flag] = DropConfig.Default end
            local MDropObj = {}
            function MDropObj:Refresh(Options, Delete) end
            function MDropObj:Set(Values)
                if DropConfig.Flag then Library.Flags[DropConfig.Flag] = Values end
                if DropConfig.Callback then DropConfig.Callback(Values) end
            end
            return MDropObj
        end

        function ElementAPI:AddBind(BindConfig)
            if BindConfig.Flag then Library.Flags[BindConfig.Flag] = BindConfig.Default end
            local BindObj = {}
            function BindObj:Set(Key)
                if BindConfig.Flag then Library.Flags[BindConfig.Flag] = Key end
            end
            return BindObj
        end

        function ElementAPI:AddTextbox(TxtConfig)
            local el = createBaseElement(30)
            local txt = Instance.new("TextBox", el)
            txt.Size = UDim2.new(1, -10, 1, 0)
            txt.Position = UDim2.new(0, 5, 0, 0)
            txt.BackgroundTransparency = 1
            txt.TextColor3 = Color3.fromRGB(255, 255, 255)
            txt.PlaceholderText = TxtConfig.Name
            txt.Text = TxtConfig.Default or ""
            
            txt.FocusLost:Connect(function(enter)
                if enter or not TxtConfig.TextDisappear then
                    if TxtConfig.Callback then TxtConfig.Callback(txt.Text) end
                    if TxtConfig.TextDisappear then txt.Text = "" end
                end
            end)
        end

        function ElementAPI:AddColorpicker(ColorConfig)
            if ColorConfig.Flag then Library.Flags[ColorConfig.Flag] = ColorConfig.Default end
            local ColorObj = {}
            function ColorObj:Set(Value)
                if ColorConfig.Flag then Library.Flags[ColorConfig.Flag] = Value end
                if ColorConfig.Callback then ColorConfig.Callback(Value) end
            end
            return ColorObj
        end

        function ElementAPI:AddThemePicker() end
        function ElementAPI:AddFontPicker() end

        function ElementAPI:AddSearch(SearchConfig)
            local SearchObj = {}
            function SearchObj:Set(text) end
            function SearchObj:Clear() end
            return SearchObj
        end

        function ElementAPI:AddConfigSection(ConfigSectionConfig)
            local ConfigObj = {}
            function ConfigObj:SetName(_, n) end
            function ConfigObj:SetId(_, i) end
            function ConfigObj:Refresh() end
            ConfigObj.Dropdown = nil
            return ConfigObj
        end

        return ElementAPI
    end

    return WindowObj
end

