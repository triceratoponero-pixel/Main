-- ║  General Tab  (server hop, rejoin, discord)
-- ══════════════════════════════════════════════════════════════════
function Nova:_BuildGeneralTab()
    local _, tabFrame = self:_CreateTabButton("⚙  General", 2)
    local notify = self._notify

    -- helper to build action cards
    local function ActionCard(yPos, iconText, titleText, descText, btnLabel, btnColor, btnHover, callback)
        local card = Instance.new("Frame")
