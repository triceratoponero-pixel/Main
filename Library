        local iconL = Instance.new("TextLabel")
        iconL.Size                   = UDim2.new(0, 24, 0, 24)
        iconL.Position               = UDim2.new(0, 10, 0, 8)
        iconL.BackgroundTransparency = 1
        iconL.Text                   = icon
        iconL.TextSize               = 16
        iconL.Font                   = Enum.Font.GothamBold
        iconL.TextColor3             = Theme.Accent
        iconL.ZIndex                 = 5
        iconL.Parent                 = card

        local lbl2 = Instance.new("TextLabel")
        lbl2.Size                   = UDim2.new(1, -10, 0, 13)
        lbl2.Position               = UDim2.new(0, 10, 0, 36)
        lbl2.BackgroundTransparency = 1
        lbl2.Text                   = label
        lbl2.TextColor3             = Theme.TextMuted
        lbl2.TextSize               = 9
        lbl2.Font                   = Enum.Font.GothamBold
        lbl2.TextXAlignment         = Enum.TextXAlignment.Left
        lbl2.ZIndex                 = 5
        lbl2.Parent                 = card

        local val = Instance.new("TextLabel")
        val.Size                   = UDim2.new(1, -10, 0, 20)
        val.Position               = UDim2.new(0, 10, 0, 13)
        val.BackgroundTransparency = 1
        val.Text                   = "—"
        val.TextColor3             = Theme.TextPrimary
        val.TextSize               = 17
        val.Font                   = Enum.Font.GothamBold
        val.TextXAlignment         = Enum.TextXAlignment.Left
        val.ZIndex                 = 5
        val.Parent                 = card
        return val
    end

    local FpsVal     = StatCard("FRAMES / SEC",  "◈", 0, 0)
    local PingVal    = StatCard("PING  ms",       "◎", 1, 0)
    local PlayersVal = StatCard("ONLINE",         "◉", 0, 1)
    local GameVal    = StatCard("PLACE ID",       "⬡", 1, 1)

    GameVal.Text     = tostring(game.PlaceId)
    GameVal.TextSize = 12

    -- FPS via heartbeat delta average
    local fpsSamples, fpsIdx, fpsSum = {}, 1, 0
    for i = 1, 10 do fpsSamples[i] = 60 end
    fpsSum = 600

    RunService.Heartbeat:Connect(function(dt)
        fpsSum = fpsSum - fpsSamples[fpsIdx]
        fpsSamples[fpsIdx] = 1 / dt
        fpsSum = fpsSum + fpsSamples[fpsIdx]
        fpsIdx = (fpsIdx % 10) + 1
        FpsVal.Text = tostring(math.floor(fpsSum / 10 + 0.5))

        local ok, ping = pcall(function()
            return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
        end)
        if ok then PingVal.Text = tostring(math.floor(ping)) end
    end)

    task.spawn(function()
        while task.wait(4) do
            PlayersVal.Text = tostring(#Players:GetPlayers())
        end
    end)
    PlayersVal.Text = tostring(#Players:GetPlayers())
end

