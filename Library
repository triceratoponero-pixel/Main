function Nova:AutoLoadConfig(name)
    if not _checkExecutor() then return end
    pcall(function()
        _ensureFolders()
        writefile(Nova.Folder .. "/autoload.txt", name)
        Nova:MakeNotification({ Name = "Config", Content = "Set " .. name .. " to auto-load.", Time = 3 })
    end)
end

function Nova:UnAutoLoadConfig()
    if not _checkExecutor() then return end
    pcall(function()
        _ensureFolders()
        local p = Nova.Folder .. "/autoload.txt"
        if isfile(p) then delfile(p) end
        Nova:MakeNotification({ Name = "Config", Content = "Disabled automatic loading templates.", Time = 3 })
    end)
end

function Nova:ShareConfigId(name)
    if not _checkExecutor() then return "" end
    local p = _configPath(name)
    if not isfile(p) then return "" end
    local content = readfile(p)
    local encoded = _b64_encode(content)
    if setclipboard then setclipboard(encoded) end
    Nova:MakeNotification({ Name = "Config Shared", Content = "Config ID copied to clipboard.", Time = 4 })
    return encoded
end

function Nova:UseConfigId(id)
    local success, data = pcall(function()
        local decoded = _b64_decode(id)
        return HttpService:JSONDecode(decoded)
    end)
    if success and data then
        for a, b in pairs(data) do
            if Nova.Flags[a] then
                if Nova.Flags[a].Type == "Colorpicker" then Nova.Flags[a]:Set(UnpackColor(b)) else Nova.Flags[a]:Set(b) end
            end
        end
        Nova:MakeNotification({ Name = "Config Injected", Content = "Config template applied successfully.", Time = 4 })
        return true
    else
        Nova:MakeNotification({ Name = "Config Error", Content = "Invalid ID formatting context.", Time = 4 })
        return false
    end
end

function Nova:SaveConfigId(name, id)
    if not id or id == "" then warn("Nova SaveConfigId: configuration ID field empty") return false end
    if not _checkExecutor() then return false end
    local ok, err = pcall(function()
        _ensureFolders()
        local raw = _b64_decode(id)
        HttpService:JSONDecode(raw)
        writefile(_configPath(name), raw)
    end)
    if not ok then
        warn("Nova SaveConfigId error:", err)
        Nova:MakeNotification({ Name = "Config Error", Content = "Failed to compile imported configuration.", Time = 4 })
        return false
    end
    Nova:MakeNotification({ Name = "Config Saved", Content = "Config File compiled from shared token setup.", Time = 4 })
    return true
end

function Nova:ListConfigs()
    if not _checkExecutor() then return {} end
    local list = {}
    local ok, files = pcall(listfiles, Nova.Folder .. "/configs")
    if not ok or not files then return list end
    for _, file in ipairs(files) do
        local n = file:match("([^/\\\\]+)%.txt$")
        if n then table.insert(list, n) end
    end
    return list
end

