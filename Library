			lbl.FontFace = style == "header"
				and Font.new("rbxasset://fonts/families/Montserrat.json", Enum.FontWeight.SemiBold)
				or  Font.new("rbxasset://fonts/families/Montserrat.json")
			lbl.Parent = ScrollFrame

			local api = {}
			function api:Set(val) lbl.Text = tostring(val) end
			function api:Get()   return lbl.Text end
			return api
		end

		-- ── DIVIDER ────────────────────────────────────────────────────────
		--- Horizontal rule with an optional inline section title.
		--- @param sectionTitle string?
		function Tab:CreateDivider(sectionTitle)
			local holder = Instance.new("Frame")
			holder.Size = UDim2.new(1, 0, 0, 24)
			holder.BackgroundTransparency = 1
			holder.Parent = ScrollFrame

			local line = Instance.new("Frame")
			line.Size = UDim2.new(1, 0, 0, 1)
			line.Position = UDim2.new(0, 0, 0.5, 0)
			line.AnchorPoint = Vector2.new(0, 0.5)
			line.BackgroundColor3 = T.Border
			line.BorderSizePixel = 0
			line.Parent = holder

			if sectionTitle and sectionTitle ~= "" then
				local bg = Instance.new("Frame")
