-- ── AddFontPicker ─────────────────────────────────────────────────
function SectionAPI:AddFontPicker(config)
    config = config or {}
    local label    = config.Title or "Font"
    local fonts    = config.Fonts or {
        Enum.Font.Gotham, Enum.Font.GothamBold, Enum.Font.SourceSans,
        Enum.Font.SourceSansBold, Enum.Font.Roboto, Enum.Font.RobotoMono,
        Enum.Font.Code,
    }
    local callback = config.Callback or function() end

    return self:AddDropdown({
        Title    = label,
        Options  = (function()
            local names = {}
            for _, f in ipairs(fonts) do table.insert(names, f.Name) end
            return names
        end)(),
        Callback = function(name)
            for _, f in ipairs(fonts) do
                if f.Name == name then callback(f) break end
            end
        end,
    })
end

-- ── AddSearch ─────────────────────────────────────────────────────
function SectionAPI:AddSearch(config)
    config = config or {}
    local placeholder = config.Placeholder or "Search..."
    local items       = config.Items or {}
    local callback    = config.Callback or function() end

    local row = MakeRow(self, 38)

    local box = Instance.new("TextBox")
    box.Size              = UDim2.new(1, -12, 0, 32)
    box.Position          = UDim2.new(0, 6, 0.5, -16)
    box.BackgroundColor3  = Theme.Surface
    box.PlaceholderText   = "  🔍  " .. placeholder
    box.PlaceholderColor3 = Theme.TextMuted
    box.Text              = ""
    box.TextColor3        = Theme.TextPrimary
    box.TextSize          = 12
    box.Font              = Enum.Font.Gotham
    box.ClearTextOnFocus  = false
    box.BorderSizePixel   = 0
    box.ZIndex            = 6
    box.Parent            = row
    Corner(box, 8)
    Stroke(box, Theme.Border, 1)
    Padding(box, 0, 8, 0, 8)

    -- results list
    local resultFrame = Instance.new("Frame")
    resultFrame.Size             = UDim2.new(1, -12, 0, 0)
    resultFrame.Position         = UDim2.new(0, 6, 1, 2)
    resultFrame.BackgroundColor3 = Theme.DropdownBg
    resultFrame.BorderSizePixel  = 0
    resultFrame.Visible          = false
    resultFrame.ZIndex           = 18
    resultFrame.ClipsDescendants = true
    resultFrame.Parent           = row
    Corner(resultFrame, 8)
    Stroke(resultFrame, Theme.Border, 1)

    local resList = Instance.new("UIListLayout")
    resList.SortOrder = Enum.SortOrder.LayoutOrder
    resList.Parent    = resultFrame
    Padding(resultFrame, 4, 4, 4, 4)

    box:GetPropertyChangedSignal("Text"):Connect(function()
        local query = box.Text:lower()
        for _, c in ipairs(resultFrame:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        if query == "" then
            resultFrame.Visible = false
            return
        end
        local results = {}
        for _, item in ipairs(items) do
            if item:lower():find(query, 1, true) then
                table.insert(results, item)
            end
        end
        if #results == 0 then
            resultFrame.Visible = false
            return
        end
        resultFrame.Size    = UDim2.new(1, -12, 0, math.min(#results, 5) * 28 + 8)
        resultFrame.Visible = true
        for i, r in ipairs(results) do
            local rb = Instance.new("TextButton")
            rb.Size             = UDim2.new(1, 0, 0, 26)
            rb.BackgroundColor3 = Theme.DropdownBg
            rb.Text             = r
            rb.TextColor3       = Theme.TextPrimary
            rb.TextSize         = 12
            rb.Font             = Enum.Font.Gotham
            rb.BorderSizePixel  = 0
            rb.ZIndex           = 19
            rb.LayoutOrder      = i
            rb.Parent           = resultFrame
            Corner(rb, 5)
            HoverEffect(rb, Theme.DropdownBg, Theme.SurfaceHover)
            rb.MouseButton1Click:Connect(function()
                box.Text = r
                resultFrame.Visible = false
                callback(r)
            end)
        end
    end)

    return {
        Get = function(_) return box.Text end,
        Set = function(_, v) box.Text = v end,
    }
end

