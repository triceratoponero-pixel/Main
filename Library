			local lStroke = Instance.new("UIStroke", listFrame)
			lStroke.Color = Color3.fromRGB(220, 220, 220)

			local listLayout = Instance.new("UIListLayout")
			listLayout.Parent = listFrame

			for _, item in pairs(list) do
				local itemBtn = Instance.new("TextButton")
				itemBtn.Size = UDim2.new(1, 0, 0, 28)
				itemBtn.BackgroundColor3 = Color3.fromRGB(250, 250, 250)
				itemBtn.BorderSizePixel = 0
				itemBtn.Text = tostring(item)
				itemBtn.Font = Enum.Font.Montserrat
				itemBtn.TextColor3 = Color3.fromRGB(140, 140, 140)
				itemBtn.TextSize = 12
				itemBtn.ZIndex = 21
				itemBtn.Parent = listFrame

				itemBtn.MouseButton1Click:Connect(function()
					if table.find(selectedItems, item) then
						table.remove(selectedItems, table.find(selectedItems, item))
						TweenService:Create(itemBtn, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(140, 140, 140)}):Play()
					else
						table.insert(selectedItems, item)
						TweenService:Create(itemBtn, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(15, 15, 15)}):Play()
					end
					
					if #selectedItems > 0 then
						btn.Text = table.concat(selectedItems, ", ")
					else
						btn.Text = "Select Multiple..."
					end
					
					if #btn.Text > 16 then
						btn.Text = string.sub(btn.Text, 1, 13) .. "..."
					end
					
					callback(selectedItems)
				end)
			end

			btn.MouseButton1Click:Connect(function()
				expanded = not expanded
				if expanded then
					listFrame.Visible = true
					local totalHeight = #list * 28
					TweenService:Create(listFrame, TweenInfo.new(0.25, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {Size = UDim2.new(0, 150, 0, totalHeight)}):Play()
					TweenService:Create(base, TweenInfo.new(0.25, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, 52 + totalHeight)}):Play()
				else
