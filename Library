local function AddConnection(Signal, Function)
    if (not Nova:IsRunning()) then return end
    local SignalConnect = Signal:Connect(Function)
    table.insert(Nova.Connections, SignalConnect)
    return SignalConnect
end

task.spawn(function()
    while (Nova:IsRunning()) do task.wait() end
    for _, Connection in next, Nova.Connections do
        Connection:Disconnect()
    end
end)

local function MakeDraggable(DragPoint, Main)
    pcall(function()
        local Dragging, DragInput, MousePos, FramePos = false
        DragPoint.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                MousePos = Input.Position
                FramePos = Main.Position

                Input.Changed:Connect(function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        Dragging = false
                    end
                end)
            end
        end)
        DragPoint.InputChanged:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
                DragInput = Input
            end
        end)
        UserInputService.InputChanged:Connect(function(Input)
            if Input == DragInput and Dragging then
                local Delta = Input.Position - MousePos
                Main.Position = UDim2.new(FramePos.X.Scale, FramePos.X.Offset + Delta.X, FramePos.Y.Scale, FramePos.Y.Offset + Delta.Y)
            end
        end)
    end)
end

-- Archetypal Instantiator Core Engine
local function Create(Name, Properties, Children)
    local Object = Instance.new(Name)
    for i, v in next, Properties or {} do Object[i] = v end
    for i, v in next, Children or {} do v.Parent = Object end
    return Object
end

local function CreateElement(ElementName, ElementFunction)
    Nova.Elements[ElementName] = function(...) return ElementFunction(...) end
end

local function MakeElement(ElementName, ...)
    return Nova.Elements[ElementName](...)
end

local function SetProps(Element, Props)
    for Property, Value in pairs(Props) do Element[Property] = Value end
    return Element
end

local function SetChildren(Element, Children)
    for _, Child in pairs(Children) do Child.Parent = Element end
    return Element
end

local function Round(Number, Factor)
    local Result = math.floor(Number/Factor + (math.sign(Number) * 0.5)) * Factor
    if Result < 0 then Result = Result + Factor end
    return Result
end

local function ReturnProperty(Object)
    if Object:IsA("Frame") or Object:IsA("TextButton") then return "BackgroundColor3" end
    if Object:IsA("ScrollingFrame") then return "ScrollBarImageColor3" end
    if Object:IsA("UIStroke") then return "Color" end
    if Object:IsA("TextLabel") or Object:IsA("TextBox") then return "TextColor3" end
    if Object:IsA("ImageLabel") or Object:IsA("ImageButton") then return "ImageColor3" end
end

local function AddThemeObject(Object, Type)
    if not Nova.ThemeObjects[Type] then Nova.ThemeObjects[Type] = {} end
    table.insert(Nova.ThemeObjects[Type], Object)
    Object[ReturnProperty(Object)] = Nova.Themes[Nova.SelectedTheme][Type]
    return Object
end

local function SetTheme()
    for Name, Type in pairs(Nova.ThemeObjects) do
        for _, Object in pairs(Type) do
            pcall(function() Object[ReturnProperty(Object)] = Nova.Themes[Nova.SelectedTheme][Name] end)
        end
    end
end

local function AddFontObject(Object)
    table.insert(Nova.FontObjects, Object)
    Object.Font = Nova.Fonts[Nova.SelectedFont] or Nova.Font
    return Object
end

local function SetFont()
    local FontEnum = Nova.Fonts[Nova.SelectedFont] or Nova.Font
    for _, Object in pairs(Nova.FontObjects) do
        pcall(function() Object.Font = FontEnum end)
    end
end

function Nova:SetTheme(ThemeName)
    if not Nova.Themes[ThemeName] then warn("Nova: Theme '" .. ThemeName .. "' not found") return end
    Nova.SelectedTheme = ThemeName
    SetTheme()
end

function Nova:SetFont(FontName)
    if not Nova.Fonts[FontName] then warn("Nova: Font '" .. FontName .. "' not found") return end
    Nova.SelectedFont = FontName
    Nova.Font = Nova.Fonts[FontName]
    SetFont()
end

-- ============================================================================
-- BASE64 & PERSISTENCE SECURITY COMPONENT LOADERS
-- ============================================================================
local function PackColor(Color) return {R = Color.R * 255, G = Color.G * 255, B = Color.B * 255} end
local function UnpackColor(Color) return Color3.fromRGB(Color.R, Color.G, Color.B) end

local b='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
local function _b64_encode(data)
    return ((data:gsub('.', function(x) 
        local r,b='',x:byte()
        for i=8,1,-1 do r=r..(b%2^i-b%2^(i-1)>0 and '1' or '0') end
        return r;
    end)..'0000'):gsub('%d%d%d%d%d%d', function(x)
        if #x<6 then return '' end
        local c=0
        for i=1,6 do c=c+(x:sub(i,i)=='1' and 2^(6-i) or 0) end
        return b:sub(c+1,c+1)
    end)..({ '', '==', '=' })[#data%3+1])
end

local function _b64_decode(data)
    data = string.gsub(data, '[^'..b..'=]', '')
    return (data:gsub('.', function(x)
        if x == '=' then return '' end
        local c=b:find(x)-1
        local r=''
        for i=6,1,-1 do r=r..(c%2^i-c%2^(i-1)>0 and '1' or '0') end
        return r;
    end):gsub('%d%d%d%d%d%d%d%d', function(x)
        local c=0
        for i=1,8 do c=c+(x:sub(i,i)=='1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

local function _checkExecutor()
    return writefile and readfile and isfolder and makefolder and listfiles and delfile
end

local function _ensureFolders()
    if not _checkExecutor() then return end
    if not isfolder(Nova.Folder) then makefolder(Nova.Folder) end
    if not isfolder(Nova.Folder .. "/configs") then makefolder(Nova.Folder .. "/configs") end
end

local function _configPath(name)
    return Nova.Folder .. "/configs/" .. name .. ".txt"
end

local function LoadCfg(Config)
    local success, err = pcall(function()
        local Data = HttpService:JSONDecode(Config)
        for a, b in pairs(Data) do
            if Nova.Flags[a] then
                task.spawn(function()
                    if Nova.Flags[a].Type == "Colorpicker" then
                        Nova.Flags[a]:Set(UnpackColor(b))
                    else
                        Nova.Flags[a]:Set(b)
                    end
                end)
            else
                warn("Nova Config Loader - Missing flag mapping reference: ", a, b)
            end
        end
    end)
    if not success then warn("Config Load Error:", err) end
end

local function SaveCfg(Name)
    if not _checkExecutor() then return false end
    local success, err = pcall(function()
        _ensureFolders()
        local Data = {}
        for i, v in pairs(Nova.Flags) do
            if v.Save then
                if v.Type == "Colorpicker" then
                    Data[i] = PackColor(v.Value)
                else
                    Data[i] = v.Value
                end
            end
        end
        writefile(Nova.Folder .. "/configs/" .. Name .. ".txt", HttpService:JSONEncode(Data))
    end)
    if not success then warn("Config Save Error:", err) return false end
    return true
end

