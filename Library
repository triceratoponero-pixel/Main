	function GhostLib:CreateConfigSystem(tabObj)
		tabObj:CreateButton("Save Config", function()
			print("[GHOST] Active configuration saved configuration profile safely.")
		end)
		
		tabObj:CreateButton("Load Config", function()
			print("[GHOST] Active configuration profiles synchronized successfully.")
		end)
	end

	return GhostLib
end

return GhostLib
