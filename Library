                AddThemeObject(SetProps(MakeElement("Label", "Premium Tab Bound Structure", 16), { Size = UDim2.new(1, -50, 0, 20), Position = UDim2.new(0, 45, 0, 14), Font = Enum.Font.FredokaOne }), "Text"),
