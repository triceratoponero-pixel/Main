		--- Static text element.
		--- @param text  string
		--- @param style string?  "normal" | "header" | "muted"
		function Tab:CreateLabel(text, style)
			assert(type(text) == "string", "CreateLabel: text must be a string")
			style = (style == "header" or style == "muted") and style or "normal"

			local size  = style == "header" and 14 or 12
			local color = style == "muted"  and T.TextMuted or T.TextSecondary
			local height = style == "header" and 32 or 24

			local lbl = Instance.new("TextLabel")
			lbl.Size = UDim2.new(1, 0, 0, height)
			lbl.BackgroundTransparency = 1
			lbl.Text = text
			lbl.TextSize = size
			lbl.TextColor3 = color
