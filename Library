    lbl.Font = Enum.Font.Gotham lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 6 lbl.Parent = row

    local swatch = Instance.new("TextButton")
    swatch.Size = UDim2.new(0,44,0,24) swatch.Position = UDim2.new(1,-50,0.5,-12)
    swatch.BackgroundColor3 = color swatch.Text = ""
    swatch.BorderSizePixel = 0 swatch.ZIndex = 6 swatch.Parent = row
    Corner(swatch, 6) Stroke(swatch, Theme.Border, 1)

    local picker = Instance.new("Frame")
    picker.Size = UDim2.new(1,-12,0,96) picker.Position = UDim2.new(0,6,1,2)
    picker.BackgroundColor3 = Theme.Surface picker.BorderSizePixel = 0
    picker.Visible = false picker.ZIndex = 15 picker.Parent = row
    Corner(picker, 8) Stroke(picker, Theme.Border, 1)

    local hueBar = Instance.new("Frame")
    hueBar.Size = UDim2.new(1,-12,0,14) hueBar.Position = UDim2.new(0,6,0,8)
    hueBar.BackgroundColor3 = Color3.fromRGB(255,255,255)
    hueBar.BorderSizePixel = 0 hueBar.ZIndex = 16 hueBar.Parent = picker
    Corner(hueBar, 4)

    local hg = Instance.new("UIGradient")
    hg.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,1,1)),
        ColorSequenceKeypoint.new(0.17, Color3.fromHSV(0.17,1,1)),
        ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33,1,1)),
        ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5,1,1)),
        ColorSequenceKeypoint.new(0.67, Color3.fromHSV(0.67,1,1)),
        ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83,1,1)),
        ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,1,1)),
    })
    hg.Parent = hueBar

    local hueH = Color3.toHSV(color)
    local hThumb = Instance.new("Frame")
    hThumb.Size = UDim2.new(0,10,1,2) hThumb.Position = UDim2.new(hueH,-5,0,-1)
    hThumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
    hThumb.BorderSizePixel = 0 hThumb.ZIndex = 17 hThumb.Parent = hueBar
    Corner(hThumb, 3)

    local presets2 = {
        Color3.fromRGB(99,102,241), Color3.fromRGB(52,211,153),
        Color3.fromRGB(251,191,36),  Color3.fromRGB(248,113,113),
        Color3.fromRGB(167,139,250), Color3.fromRGB(56,189,248),
        Color3.fromRGB(255,255,255), Color3.fromRGB(50,50,70),
    }
    for i, pc in ipairs(presets2) do
        local ps = Instance.new("TextButton")
        ps.Size = UDim2.new(0,22,0,22) ps.Position = UDim2.new(0,6+(i-1)*26,0,30)
        ps.BackgroundColor3 = pc ps.Text = ""
        ps.BorderSizePixel = 0 ps.ZIndex = 16 ps.Parent = picker
        Corner(ps, 5)
        ps.MouseButton1Click:Connect(function()
            color = pc
            Tween(swatch, {BackgroundColor3 = color}, 0.1)
            local h2 = Color3.toHSV(color)
            Tween(hThumb, {Position = UDim2.new(h2,-5,0,-1)}, 0.1)
            callback(color)
        end)
    end

    local hDrag2 = false
    hueBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            hDrag2 = true
            local rel = math.clamp((i.Position.X-hueBar.AbsolutePosition.X)/hueBar.AbsoluteSize.X,0,1)
            color = Color3.fromHSV(rel,1,1)
            hThumb.Position = UDim2.new(rel,-5,0,-1)
            Tween(swatch,{BackgroundColor3=color},0.05); callback(color)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then hDrag2 = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if hDrag2 and i.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = math.clamp((i.Position.X-hueBar.AbsolutePosition.X)/hueBar.AbsoluteSize.X,0,1)
            color = Color3.fromHSV(rel,1,1)
            hThumb.Position = UDim2.new(rel,-5,0,-1)
            Tween(swatch,{BackgroundColor3=color},0.05); callback(color)
        end
    end)

    swatch.MouseButton1Click:Connect(function()
        open = not open
        if open then
            picker.Visible = true
            Tween(picker, {Size = UDim2.new(1,-12,0,96)}, 0.2, Enum.EasingStyle.Back)
        else
            Tween(picker, {Size = UDim2.new(1,-12,0,0)}, 0.15)
            task.delay(0.16, function() picker.Visible = false end)
        end
    end)
    return { Set = function(_,c) color=c; Tween(swatch,{BackgroundColor3=c},0.1); callback(c) end, Get = function(_) return color end }
end

