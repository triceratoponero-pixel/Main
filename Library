                                Parent = SliderFrame
                        }), "TextDark")

                        local Track = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 3), {
                                Size = UDim2.new(1, 0, 0, 6),
                                Position = UDim2.new(0, 0, 0, 34),
                                Parent = SliderFrame,
                                BackgroundTransparency = 0.5
                        }), {
                                MakeElement("Corner", 1)
                        }), "Main")

                        local Fill = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 3), {
                                Size = UDim2.new(0, 0, 1, 0),
                                Parent = Track,
                                BackgroundTransparency = 0
                        }), {
                                MakeElement("Corner", 1)
                        }), "Stroke")

                        local ActiveButton = SetProps(MakeElement("Button"), {
                                Size = UDim2.new(1, 0, 1, 0),
                                Parent = Track
                        })

                        local Sliding = false

                        local function UpdateSlider(NewValue)
                                Value = math.clamp(Round(NewValue, SliderConfig.Increment), SliderConfig.Min, SliderConfig.Max)
                                ValueLabel.Text = tostring(Value)
                                local Percentage = (Value - SliderConfig.Min) / (SliderConfig.Max - SliderConfig.Min)
                                TweenService:Create(Fill, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {Size = UDim2.new(Percentage, 0, 1, 0)}):Play()
                                if SliderConfig.Flag ~= "" then
                                        Library.Flags[SliderConfig.Flag].Value = Value
                                end
                                SliderConfig.Callback(Value)
                        end

                        local function SnapToMouse()
                                if not Library:IsRunning() then return end
                                local Percent = math.clamp((Mouse.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                                local TheoreticalValue = SliderConfig.Min + (Percent * (SliderConfig.Max - SliderConfig.Min))
                                UpdateSlider(TheoreticalValue)
                        end

                        AddConnection(ActiveButton.InputBegan, function(Input)
                                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                                        Sliding = true
                                        SnapToMouse()
                                end
                        end)

                        AddConnection(UserInputService.InputEnded, function(Input)
                                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                                        Sliding = false
                                end
                        end)

                        AddConnection(UserInputService.InputChanged, function(Input)
                                if Sliding and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                                        SnapToMouse()
                                end
                        end)

                        if SliderConfig.Flag ~= "" then
                                Library.Flags[SliderConfig.Flag] = {
                                        Type = "Slider",
                                        Value = Value,
                                        Save = true,
                                        Set = function(self, State)
