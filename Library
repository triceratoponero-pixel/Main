-- ─── HELPERS ──────────────────────────────────────────────────────────────────

local function Tween(inst, info, props)
	return TweenService:Create(inst, info, props)
end

local function RoundFrame(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or C.CORNER_RADIUS)
	c.Parent = parent
	return c
end

local function Stroke(parent, color, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color or Color3.fromRGB(45, 45, 45)
	s.Thickness = thickness or 1
	s.Parent = parent
	return s
end

-- ─── INFO POPOVER & BUTTON ───────────────────────────────────────────────────

local InfoPopover = nil

local function showInfo(anchor, description)
	if not description or description == "" then return end
	if not InfoPopover then
		InfoPopover = Instance.new("Frame")
		InfoPopover.Name = "GhostInfoPopover"
		InfoPopover.BackgroundColor3 = T.Surface
		InfoPopover.BorderSizePixel = 0
		InfoPopover.ZIndex = 10000
		InfoPopover.Visible = false
		InfoPopover.Parent = ScreenGui
		RoundFrame(InfoPopover, 8)
		Stroke(InfoPopover, T.Border)

		local padding = Instance.new("UIPadding")
		padding.PaddingAll = UDim.new(0, 12)
		padding.Parent = InfoPopover

		local text = Instance.new("TextLabel")
		text.Name = "Content"
		text.BackgroundTransparency = 1
		text.TextColor3 = T.TextSecondary
		text.TextSize = 13
		text.Font = Enum.Font.Montserrat
		text.TextXAlignment = Enum.TextXAlignment.Left
		text.TextYAlignment = Enum.TextYAlignment.Top
		text.TextWrapped = true
		text.Parent = InfoPopover
	end

	local content = InfoPopover:FindFirstChild("Content")
	content.Text = description
	InfoPopover.Size = UDim2.new(0, 280, 0, math.clamp(content.TextBounds.Y + 40, 60, 220))

	local absPos = anchor.AbsolutePosition
	InfoPopover.Position = UDim2.new(0, absPos.X + 35, 0, absPos.Y - 10)
	InfoPopover.Visible = true

	task.delay(0.1, function()
		local conn = UserInputService.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				InfoPopover.Visible = false
				conn:Disconnect()
			end
		end)
	end)
end

local function CreateInfoButton(parent, description)
	if not description or description == "" then return end

	local infoBtn = Instance.new("TextButton")
	infoBtn.Size = UDim2.new(0, 22, 0, 22)
	infoBtn.Position = UDim2.new(1, -34, 0.5, -11)
	infoBtn.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
	infoBtn.Text = "i"
	infoBtn.TextColor3 = Color3.fromRGB(170, 170, 170)
	infoBtn.Font = Enum.Font.Montserrat
	infoBtn.TextSize = 13
	infoBtn.Parent = parent
	RoundFrame(infoBtn, 999)
	Stroke(infoBtn, Color3.fromRGB(70, 70, 70))

	infoBtn.MouseEnter:Connect(function() Tween(infoBtn, C.TWEEN_FAST, {BackgroundColor3 = Color3.fromRGB(75,75,75)}):Play() end)
	infoBtn.MouseLeave:Connect(function() Tween(infoBtn, C.TWEEN_FAST, {BackgroundColor3 = Color3.fromRGB(55,55,55)}):Play() end)

	infoBtn.MouseButton1Click:Connect(function() showInfo(infoBtn, description) end)
end

