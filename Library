		-- SLIDER
		function Tab:CreateSlider(name, min, max, default, callback, description)
			assert(type(min) == "number" and type(max) == "number", "Slider '" .. name .. "': min/max must be numbers")
			assert(min < max, "Slider '" .. name .. "': min must be less than max")
			assert(type(callback) == "function", "Slider '" .. name .. "': callback must be a function")
			default = math.clamp(default or min, min, max)

			local base, lbl = CreateElementBase(name, ScrollFrame, nil, description)

			local valLabel = Instance.new("TextLabel")
			valLabel.Size = UDim2.new(0, 45, 1, 0)
			valLabel.Position = UDim2.new(1, -61, 0, 0)
			valLabel.BackgroundTransparency = 1
			valLabel.Text = tostring(default)
			valLabel.Font = Enum.Font.Montserrat
			valLabel.TextSize = 13
			valLabel.TextColor3 = T.TextMuted
			valLabel.Parent = base

			local track = Instance.new("Frame")
			track.Size = UDim2.new(0, 150, 0, 6)
			track.Position = UDim2.new(1, -220, 0.5, -3)
			track.BackgroundColor3 = T.ToggleOff
			track.BorderSizePixel = 0
			track.Parent = base
			RoundFrame(track, 999)

			local fill = Instance.new("Frame")
			fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
			fill.BackgroundColor3 = T.Accent
			fill.BorderSizePixel = 0
			fill.Parent = track
			RoundFrame(fill, 999)

			-- Draggable handle
			local handle = Instance.new("Frame")
			handle.Size = UDim2.new(0, 14, 0, 14)
			handle.AnchorPoint = Vector2.new(0.5, 0.5)
			handle.Position = UDim2.new((default - min) / (max - min), 0, 0.5, 0)
			handle.BackgroundColor3 = T.Accent
			handle.BorderSizePixel = 0
			handle.ZIndex = 2
			handle.Parent = track
			RoundFrame(handle, 999)

			local hitbox = Instance.new("TextButton")
			hitbox.Size = UDim2.new(1, 12, 3, 0)
			hitbox.Position = UDim2.new(0, -6, -1, 0)
			hitbox.BackgroundTransparency = 1
			hitbox.Text = ""
			hitbox.ZIndex = 3
			hitbox.Parent = track

			local function UpdateSlider()
				-- Use AbsolutePosition for correct value even after window drag
				local barLeft  = track.AbsolutePosition.X
				local barWidth = track.AbsoluteSize.X
				local mouseX   = UserInputService:GetMouseLocation().X
				local pct      = math.clamp((mouseX - barLeft) / barWidth, 0, 1)
				local value    = math.round(min + pct * (max - min))
				pct = (value - min) / (max - min)     -- snap to integer grid

				Tween(fill,   TweenInfo.new(0.05), {Size     = UDim2.new(pct, 0, 1, 0)}):Play()
				Tween(handle, TweenInfo.new(0.05), {Position = UDim2.new(pct, 0, 0.5, 0)}):Play()
				valLabel.Text = tostring(value)
				callback(value)
			end

			local sliding = false
			hitbox.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch then
					sliding = true
					Tween(track, C.TWEEN_FAST, {Size = UDim2.new(0, 150, 0, 8)}):Play()
					Tween(handle, C.TWEEN_FAST, {Size = UDim2.new(0, 16, 0, 16)}):Play()
					UpdateSlider()
				end
			end)

			Track(UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch then
					if sliding then
						sliding = false
						Tween(track,  C.TWEEN_FAST, {Size = UDim2.new(0, 150, 0, 6)}):Play()
						Tween(handle, C.TWEEN_FAST, {Size = UDim2.new(0, 14, 0, 14)}):Play()
					end
				end
			end))

			Track(UserInputService.InputChanged:Connect(function(input)
				if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement
					or input.UserInputType == Enum.UserInputType.Touch) then
					UpdateSlider()
				end
			end))

			local api = {}
			function api:Set(val)
				val = math.clamp(math.round(val), min, max)
				local pct = (val - min) / (max - min)
				fill.Size   = UDim2.new(pct, 0, 1, 0)
				handle.Position = UDim2.new(pct, 0, 0.5, 0)
				valLabel.Text = tostring(val)
			end
			return api
		end

		-- KEYBIND
		function Tab:CreateKeybind(name, default, callback, description)
			assert(type(callback) == "function", "Keybind '" .. name .. "': callback must be a function")
			local currentBind = default or Enum.KeyCode.RightControl
			local base, lbl = CreateElementBase(name, ScrollFrame, nil, description)
			local listening   = false

			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(0, 110, 0, 28)
			btn.Position = UDim2.new(1, -126, 0.5, -14)
			btn.BackgroundColor3 = T.Input
			btn.Font = Enum.Font.Montserrat
			btn.Text = currentBind.Name
			btn.TextColor3 = T.TextSecondary
			btn.TextSize = 12
			btn.Parent = base
			RoundFrame(btn, 6)
			local bStroke = Stroke(btn, T.InputBorder)

			btn.MouseButton1Click:Connect(function()
				if listening then return end
				listening = true
				btn.Text = "Press a key…"
				Tween(btn,    C.TWEEN_FAST, {BackgroundColor3 = T.ElementHover}):Play()
				Tween(bStroke,C.TWEEN_FAST, {Color = T.BorderFocus}):Play()
			end)

			-- Fix: only capture while listening and skip if a TextBox is focused
			Track(UserInputService.InputBegan:Connect(function(input, processed)
				if not listening then return end
				-- Don't capture if typing in a text field
				if processed then return end
				if input.UserInputType == Enum.UserInputType.Keyboard then
					-- Ignore modifier-only presses
					if input.KeyCode == Enum.KeyCode.Unknown then return end
					listening = false
					currentBind = input.KeyCode
					btn.Text = currentBind.Name
					Tween(btn,    C.TWEEN_FAST, {BackgroundColor3 = T.Input}):Play()
					Tween(bStroke,C.TWEEN_FAST, {Color = T.InputBorder}):Play()
					callback(currentBind)
				end
			end))

			local api = {}
			function api:Get() return currentBind end
			return api
		end

		-- TEXTBOX
		function Tab:CreateTextBox(name, placeholder, callback, description)
			assert(type(callback) == "function", "TextBox '" .. name .. "': callback must be a function")
			local base, lbl = CreateElementBase(name, ScrollFrame, nil, description)

			local box = Instance.new("TextBox")
			box.Size = UDim2.new(0, 150, 0, 28)
			box.Position = UDim2.new(1, -166, 0.5, -14)
			box.BackgroundColor3 = T.Input
			box.Text = ""
			box.PlaceholderText = placeholder or "Enter text..."
			box.PlaceholderColor3 = T.TextDisabled
			box.Font = Enum.Font.Montserrat
			box.TextSize = 12
			box.TextColor3 = T.TextSecondary
			box.ClearTextOnFocus = false
			box.Parent = base
			RoundFrame(box, 6)
			local bStroke = Stroke(box, T.InputBorder)

			box.Focused:Connect(function()
				Tween(bStroke, C.TWEEN_FAST, {Color = T.BorderFocus}):Play()
				Tween(base,    C.TWEEN_FAST, {BackgroundColor3 = T.ElementHover}):Play()
			end)
			box.FocusLost:Connect(function(enter)
				Tween(bStroke, C.TWEEN_FAST, {Color = T.InputBorder}):Play()
				Tween(base,    C.TWEEN_FAST, {BackgroundColor3 = T.Element}):Play()
				callback(box.Text, enter)
			end)

			local api = {}
			function api:Set(val) box.Text = tostring(val) end
			function api:Get()    return box.Text end
			return api
		end

		-- DROPDOWN (single select)
		function Tab:CreateDropdown(name, list, callback, description)
			assert(type(list) == "table" and #list > 0, "Dropdown '" .. name .. "': list must be a non-empty table")
			assert(type(callback) == "function", "Dropdown '" .. name .. "': callback must be a function")

			local base, lbl = CreateElementBase(name, ScrollFrame, C.ELEM_HEIGHT, description)
			local expanded  = false
			local selected  = nil

			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(0, 150, 0, 28)
			btn.Position = UDim2.new(1, -166, 0, 9)
			btn.BackgroundColor3 = T.Input
			btn.Font = Enum.Font.Montserrat
			btn.Text = "Select..."
			btn.TextColor3 = T.TextSecondary
			btn.TextSize = 12
			btn.Parent = base
			RoundFrame(btn, 6)
			local bStroke = Stroke(btn, T.InputBorder)

			local listFrame = Instance.new("ScrollingFrame")
			listFrame.Size = UDim2.new(0, 150, 0, 0)
			listFrame.Position = UDim2.new(1, -166, 0, 42)
			listFrame.BackgroundColor3 = T.Dropdown
			listFrame.BorderSizePixel = 0
			listFrame.Visible = false
			listFrame.ClipsDescendants = true
			listFrame.ZIndex = 20
			listFrame.ScrollBarThickness = 2
			listFrame.ScrollBarImageColor3 = Color3.fromRGB(80,80,80)
			listFrame.CanvasSize = UDim2.new(0, 0, 0, #list * 28)
			listFrame.Parent = base
			RoundFrame(listFrame, 6)
			Stroke(listFrame, T.Border)
			Instance.new("UIListLayout").Parent = listFrame

			local function Collapse()
				expanded = false
				local t = Tween(listFrame, C.TWEEN_MED, {Size = UDim2.new(0, 150, 0, 0)})
				t:Play()
				Tween(base, C.TWEEN_MED, {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT)}):Play()
				Tween(bStroke, C.TWEEN_FAST, {Color = T.InputBorder}):Play()
				t.Completed:Connect(function() if not expanded then listFrame.Visible = false end end)
			end

			local function Expand()
				expanded = true
				listFrame.Visible = true
				local h = math.min(#list * 28, 112)
				Tween(listFrame, C.TWEEN_CUBIC, {Size = UDim2.new(0, 150, 0, h)}):Play()
				Tween(base, C.TWEEN_CUBIC, {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT + 6 + h)}):Play()
				Tween(bStroke, C.TWEEN_FAST, {Color = T.BorderFocus}):Play()
			end

			for _, item in pairs(list) do
				local itemBtn = Instance.new("TextButton")
				itemBtn.Size = UDim2.new(1, 0, 0, 28)
				itemBtn.BackgroundTransparency = 1
				itemBtn.Text = tostring(item)
				itemBtn.Font = Enum.Font.Montserrat
				itemBtn.TextColor3 = T.TextMuted
				itemBtn.TextSize = 12
				itemBtn.ZIndex = 21
				itemBtn.Parent = listFrame

				itemBtn.MouseEnter:Connect(function()
					Tween(itemBtn, C.TWEEN_FAST, {BackgroundColor3 = T.DropdownSel, BackgroundTransparency = 0}):Play()
					Tween(itemBtn, C.TWEEN_FAST, {TextColor3 = T.DropdownSelTx}):Play()
				end)
				itemBtn.MouseLeave:Connect(function()
					if selected ~= item then
						Tween(itemBtn, C.TWEEN_FAST, {BackgroundTransparency = 1}):Play()
						Tween(itemBtn, C.TWEEN_FAST, {TextColor3 = T.TextMuted}):Play()
					end
				end)

				itemBtn.MouseButton1Click:Connect(function()
					selected = item
					btn.Text = tostring(item)
					Collapse()
					callback(item)
				end)
			end

			btn.MouseButton1Click:Connect(function()
				if expanded then Collapse() else Expand() end
			end)

			local api = {}
			function api:Set(val)
				selected = val
				btn.Text = tostring(val)
			end
			function api:Get() return selected end
			return api
		end

		-- MULTI-DROPDOWN
		function Tab:CreateMultiDropdown(name, list, options, callback, description)
			if type(options) == "function" then
				callback = options
				options = {}
			end
			options = options or {}
			local closeOnSelect = options.CloseOnSelect == true

			assert(type(list) == "table" and #list > 0, "MultiDropdown '" .. name .. "': list must be a non-empty table")
			assert(type(callback) == "function", "MultiDropdown '" .. name .. "': callback must be a function")

			local base, lbl = CreateElementBase(name, ScrollFrame, C.ELEM_HEIGHT, description)
			local expanded  = false
			local selected  = {}

			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(0, 150, 0, 28)
			btn.Position = UDim2.new(1, -166, 0, 9)
			btn.BackgroundColor3 = T.Input
			btn.Font = Enum.Font.Montserrat
			btn.Text = "Multiple..."
			btn.TextColor3 = T.TextSecondary
			btn.TextSize = 12
			btn.Parent = base
			RoundFrame(btn, 6)
			local bStroke = Stroke(btn, T.InputBorder)

			local listFrame = Instance.new("ScrollingFrame")
			listFrame.Size = UDim2.new(0, 150, 0, 0)
			listFrame.Position = UDim2.new(1, -166, 0, 42)
			listFrame.BackgroundColor3 = T.Dropdown
			listFrame.BorderSizePixel = 0
			listFrame.Visible = false
			listFrame.ClipsDescendants = true
			listFrame.ZIndex = 20
			listFrame.ScrollBarThickness = 2
			listFrame.ScrollBarImageColor3 = Color3.fromRGB(80,80,80)
			listFrame.CanvasSize = UDim2.new(0, 0, 0, #list * 28)
			listFrame.Parent = base
			RoundFrame(listFrame, 6)
			Stroke(listFrame, T.Border)
			Instance.new("UIListLayout").Parent = listFrame

			local function UpdateBtnText()
				if #selected == 0 then
					btn.Text = "Multiple..."
				else
					local t = table.concat(selected, ", ")
					btn.Text = #t > 16 and string.sub(t, 1, 13) .. "…" or t
				end
			end

			local function Collapse()
				expanded = false
				local t = Tween(listFrame, C.TWEEN_MED, {Size = UDim2.new(0, 150, 0, 0)})
				t:Play()
				Tween(base, C.TWEEN_MED, {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT)}):Play()
				Tween(bStroke, C.TWEEN_FAST, {Color = T.InputBorder}):Play()
				t.Completed:Connect(function() if not expanded then listFrame.Visible = false end end)
			end

			local function Expand()
				expanded = true
				listFrame.Visible = true
				local h = math.min(#list * 28, 112)
				Tween(listFrame, C.TWEEN_CUBIC, {Size = UDim2.new(0, 150, 0, h)}):Play()
				Tween(base, C.TWEEN_CUBIC, {Size = UDim2.new(1, 0, 0, C.ELEM_HEIGHT + 6 + h)}):Play()
				Tween(bStroke, C.TWEEN_FAST, {Color = T.BorderFocus}):Play()
			end

			for _, item in pairs(list) do
				local itemBtn = Instance.new("TextButton")
				itemBtn.Size = UDim2.new(1, 0, 0, 28)
				itemBtn.BackgroundColor3 = T.DropdownItem
				itemBtn.BackgroundTransparency = 0
				itemBtn.BorderSizePixel = 0
				itemBtn.Text = tostring(item)
				itemBtn.Font = Enum.Font.Montserrat
				itemBtn.TextColor3 = T.TextMuted
				itemBtn.TextSize = 12
				itemBtn.ZIndex = 21
				itemBtn.Parent = listFrame

				itemBtn.MouseButton1Click:Connect(function()
					local idx = table.find(selected, item)
					if idx then
						table.remove(selected, idx)
						Tween(itemBtn, C.TWEEN_FAST, {
							TextColor3 = T.TextMuted,
							BackgroundColor3 = T.DropdownItem
						}):Play()
					else
						table.insert(selected, item)
						Tween(itemBtn, C.TWEEN_FAST, {
							TextColor3 = T.DropdownSelTx,
							BackgroundColor3 = T.DropdownSel
						}):Play()
					end
					UpdateBtnText()
					callback(selected)
					if closeOnSelect then Collapse() end
				end)
			end

			btn.MouseButton1Click:Connect(function()
				if expanded then Collapse() else Expand() end
			end)

			local api = {}
			function api:Get() return selected end
			function api:Clear()
				selected = {}
				UpdateBtnText()
			end
			return api
		end

