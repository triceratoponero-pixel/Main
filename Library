-- ║  Nova.new()
-- ══════════════════════════════════════════════════════════════════
function Nova.new(config)
    config = config or {}
    local self      = setmetatable({}, Nova)
    self.Title      = config.Title  or "Nova"
    self.Width      = config.Width  or 570
    self.Height     = config.Height or 460
    self.Tabs       = {}
    self._minimized = false

    -- ── ScreenGui ────────────────────────────────────────────────
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name           = "NovaUI_" .. self.Title
    ScreenGui.ResetOnSpawn   = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.DisplayOrder   = 999
    pcall(function() ScreenGui.Parent = CoreGui end)
    if not ScreenGui.Parent then
        ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end
    self.ScreenGui = ScreenGui

    -- ── Shadow layer (behind main) ────────────────────────────────
    local Shadow = Instance.new("ImageLabel")
    Shadow.Name                  = "Shadow"
    Shadow.Size                  = UDim2.new(0, self.Width + 60, 0, self.Height + 60)
    Shadow.Position              = UDim2.new(0.5, -(self.Width + 60)/2, 0.5, -(self.Height + 60)/2)
    Shadow.BackgroundTransparency = 1
    Shadow.Image                 = "rbxassetid://6015897843"
    Shadow.ImageColor3           = Color3.fromRGB(0, 0, 0)
    Shadow.ImageTransparency     = 0.5
    Shadow.ScaleType             = Enum.ScaleType.Slice
    Shadow.SliceCenter           = Rect.new(49, 49, 450, 450)
    Shadow.ZIndex                = 0
    Shadow.Parent                = ScreenGui

    -- ── Main Frame ────────────────────────────────────────────────
    -- Start scaled to 0 for open animation
    local Main = Instance.new("Frame")
    Main.Name             = "Main"
    Main.Size             = UDim2.new(0, 0, 0, 0)
    Main.Position         = UDim2.new(0.5, 0, 0.5, 0)
    Main.BackgroundColor3 = Theme.Background
    Main.BorderSizePixel  = 0
    Main.ClipsDescendants = true
    Main.ZIndex           = 1
    Main.Parent           = ScreenGui
    Corner(Main, 12)
    Stroke(Main, Theme.Border, 1)

    local BG = Instance.new("UIGradient")
    BG.Rotation = 140
    BG.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(16, 16, 26)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(9,   9, 16)),
    })
    BG.Parent = Main
    self.Main = Main

    -- Sync shadow position when main moves
    RunService.RenderStepped:Connect(function()
        Shadow.Position = UDim2.new(
            0, Main.AbsolutePosition.X - 30,
            0, Main.AbsolutePosition.Y - 30
        )
        Shadow.Size = UDim2.new(0, Main.AbsoluteSize.X + 60, 0, Main.AbsoluteSize.Y + 60)
    end)

    -- Open animation: spring in from center
    task.defer(function()
        TweenSpring(Main, {
            Size     = UDim2.new(0, self.Width, 0, self.Height),
            Position = UDim2.new(0.5, -self.Width/2, 0.5, -self.Height/2),
        }, 0.45)
    end)

    -- ── Title Bar ─────────────────────────────────────────────────
    local TitleBar = Instance.new("Frame")
    TitleBar.Name             = "TitleBar"
    TitleBar.Size             = UDim2.new(1, 0, 0, 44)
    TitleBar.BackgroundColor3 = Theme.TitleBar
    TitleBar.BorderSizePixel  = 0
    TitleBar.ZIndex           = 5
    TitleBar.Parent           = Main
    Corner(TitleBar, 12)

    -- fill bottom corners square
    local TBFill = Instance.new("Frame")
    TBFill.Size             = UDim2.new(1, 0, 0, 12)
    TBFill.Position         = UDim2.new(0, 0, 1, -12)
    TBFill.BackgroundColor3 = Theme.TitleBar
    TBFill.BorderSizePixel  = 0
    TBFill.ZIndex           = 4
    TBFill.Parent           = TitleBar

    local AccentLine = Instance.new("Frame")
    AccentLine.Size             = UDim2.new(1, 0, 0, 1)
    AccentLine.Position         = UDim2.new(0, 0, 1, -1)
    AccentLine.BackgroundColor3 = Theme.Border
    AccentLine.BorderSizePixel  = 0
    AccentLine.ZIndex           = 6
    AccentLine.Parent           = TitleBar

    -- animated accent dot (pulses)
    local Dot = Instance.new("Frame")
    Dot.Size             = UDim2.new(0, 8, 0, 8)
    Dot.Position         = UDim2.new(0, 14, 0.5, -4)
    Dot.BackgroundColor3 = Theme.Accent
    Dot.BorderSizePixel  = 0
    Dot.ZIndex           = 7
    Dot.Parent           = TitleBar
    Corner(Dot, 4)

    -- dot pulse animation
    task.spawn(function()
        while Dot.Parent do
            Tween(Dot, {BackgroundColor3 = Theme.AccentHover, Size = UDim2.new(0, 10, 0, 10), Position = UDim2.new(0, 13, 0.5, -5)}, 0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(0.85)
            Tween(Dot, {BackgroundColor3 = Theme.Accent, Size = UDim2.new(0, 8, 0, 8), Position = UDim2.new(0, 14, 0.5, -4)}, 0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(0.85)
        end
    end)

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size                   = UDim2.new(0, 220, 1, 0)
    TitleLabel.Position               = UDim2.new(0, 30, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text                   = self.Title
    TitleLabel.TextColor3             = Theme.TextPrimary
    TitleLabel.TextSize               = 14
    TitleLabel.Font                   = Enum.Font.GothamBold
    TitleLabel.TextXAlignment         = Enum.TextXAlignment.Left
    TitleLabel.ZIndex                 = 6
    TitleLabel.Parent                 = TitleBar

    -- ── Window control buttons (kept 8px from right edge, INSIDE frame) ──
    -- Close button at X=-8 offset from right (22px wide → right edge at -8, left edge at -30)
    local function MakeWinBtn(rightOffset, col, hoverCol, symbol)
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(0, 22, 0, 22)
        btn.Position         = UDim2.new(1, rightOffset, 0.5, -11)
        btn.BackgroundColor3 = col
        btn.Text             = ""
        btn.BorderSizePixel  = 0
        btn.ZIndex           = 10
        btn.Parent           = TitleBar
        Corner(btn, 11)

        local icon = Instance.new("TextLabel")
        icon.Size                   = UDim2.new(1, 0, 1, 0)
        icon.BackgroundTransparency = 1
        icon.Text                   = symbol
        icon.TextColor3             = Color3.fromRGB(255, 255, 255)
        icon.TextTransparency       = 0.3
        icon.TextSize               = 11
        icon.Font                   = Enum.Font.GothamBold
        icon.ZIndex                 = 11
        icon.Parent                 = btn

        -- icon reveals on hover
        btn.MouseEnter:Connect(function()
            Tween(btn,  {BackgroundColor3 = hoverCol}, 0.12)
            Tween(icon, {TextTransparency = 0}, 0.1)
            Tween(btn,  {Size = UDim2.new(0, 24, 0, 24), Position = UDim2.new(1, rightOffset - 1, 0.5, -12)}, 0.12)
        end)
        btn.MouseLeave:Connect(function()
            Tween(btn,  {BackgroundColor3 = col}, 0.12)
            Tween(icon, {TextTransparency = 0.3}, 0.12)
            Tween(btn,  {Size = UDim2.new(0, 22, 0, 22), Position = UDim2.new(1, rightOffset, 0.5, -11)}, 0.12)
        end)
        return btn, icon
    end

    -- Close:    right edge at -8  → position offset = -(8 + 22) = -30
    -- Minimize: right edge at -36 → position offset = -(36 + 22) = -58
    local CloseBtn    = MakeWinBtn(-30, Theme.Danger,  Theme.DangerHover,  "✕")
    local MinimizeBtn = MakeWinBtn(-58, Theme.Warning, Theme.WarningHover, "—")

    local fullHeight = self.Height
    MinimizeBtn.MouseButton1Click:Connect(function()
        self._minimized = not self._minimized
        if self._minimized then
            Tween(Main, {Size = UDim2.new(0, self.Width, 0, 44)}, 0.3, Enum.EasingStyle.Quart)
        else
            TweenSpring(Main, {Size = UDim2.new(0, self.Width, 0, fullHeight)}, 0.4)
        end
    end)

    CloseBtn.MouseButton1Click:Connect(function()
        Tween(Main,   {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        Tween(Shadow, {ImageTransparency = 1}, 0.25)
        task.delay(0.32, function() ScreenGui:Destroy() end)
    end)

    MakeDraggable(Main, TitleBar)
    self.TitleBar = TitleBar

    -- ── Tab Bar ───────────────────────────────────────────────────
    local TabBar = Instance.new("ScrollingFrame")
    TabBar.Name                  = "TabBar"
    TabBar.Size                  = UDim2.new(1, 0, 0, 36)
    TabBar.Position              = UDim2.new(0, 0, 0, 44)
    TabBar.BackgroundColor3      = Theme.TitleBar
    TabBar.BorderSizePixel       = 0
    TabBar.ScrollBarThickness    = 0
    TabBar.CanvasSize            = UDim2.new(0, 0, 0, 0)
    TabBar.AutomaticCanvasSize   = Enum.AutomaticSize.X
    TabBar.ScrollingDirection    = Enum.ScrollingDirection.X
    TabBar.ZIndex                = 5
    TabBar.Parent                = Main

    local TabList = Instance.new("UIListLayout")
    TabList.FillDirection = Enum.FillDirection.Horizontal
    TabList.SortOrder     = Enum.SortOrder.LayoutOrder
    TabList.Padding       = UDim.new(0, 2)
    TabList.Parent        = TabBar
    Padding(TabBar, 5, 6, 5, 6)

    local TabDivider = Instance.new("Frame")
    TabDivider.Size             = UDim2.new(1, 0, 0, 1)
    TabDivider.Position         = UDim2.new(0, 0, 1, -1)
    TabDivider.BackgroundColor3 = Theme.Border
    TabDivider.BorderSizePixel  = 0
    TabDivider.ZIndex           = 6
    TabDivider.Parent           = TabBar
    self.TabBar = TabBar

    -- ── Content Area ──────────────────────────────────────────────
    local ContentArea = Instance.new("Frame")
    ContentArea.Name              = "ContentArea"
    ContentArea.Size              = UDim2.new(1, 0, 1, -82)
    ContentArea.Position          = UDim2.new(0, 0, 0, 82)
    ContentArea.BackgroundColor3  = Theme.Background
    ContentArea.BorderSizePixel   = 0
    ContentArea.ClipsDescendants  = true
    ContentArea.ZIndex            = 2
    ContentArea.Parent            = Main
    self.ContentArea = ContentArea

    -- store notify helper on self
    self._notify = function(msg, col, dur)
        Notify(ScreenGui, msg, col, dur)
    end

    -- ── Built-in tabs ─────────────────────────────────────────────
    self:_BuildStatusTab()
    self:_BuildGeneralTab()

    return self
end

