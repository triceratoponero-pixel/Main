-- ── AddSearch ────────────────────────────────────────────────────
function SectionAPI:AddSearch(config)
    config = config or {}
    local placeholder = config.Placeholder or "Search..."
    local items       = config.Items or {}
    local callback    = config.Callback or function() end
    local row = MakeRow(self, 38)

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(1,-12,0,32) box.Position = UDim2.new(0,6,0.5,-16)
    box.BackgroundColor3 = Theme.Surface
    box.PlaceholderText = "  🔍  "..placeholder
    box.PlaceholderColor3 = Theme.TextMuted box.Text = ""
    box.TextColor3 = Theme.TextPrimary box.TextSize = 12
    box.Font = Enum.Font.Gotham box.ClearTextOnFocus = false
    box.BorderSizePixel = 0 box.ZIndex = 6 box.Parent = row
    Corner(box, 8) Stroke(box, Theme.Border, 1) Padding(box, 0, 8, 0, 8)

    local rf = Instance.new("Frame")
    rf.Size = UDim2.new(1,-12,0,0) rf.Position = UDim2.new(0,6,1,2)
    rf.BackgroundColor3 = Theme.DropdownBg rf.BorderSizePixel = 0
    rf.Visible = false rf.ZIndex = 18 rf.ClipsDescendants = true rf.Parent = row
    Corner(rf, 8) Stroke(rf, Theme.Border, 1)
    Instance.new("UIListLayout").Parent = rf
    Padding(rf, 4, 4, 4, 4)

    box:GetPropertyChangedSignal("Text"):Connect(function()
        local q = box.Text:lower()
        for _, c in ipairs(rf:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        if q == "" then rf.Visible = false; return end
        local res = {}
        for _, item in ipairs(items) do
            if item:lower():find(q, 1, true) then table.insert(res, item) end
        end
        if #res == 0 then rf.Visible = false; return end
        rf.Size = UDim2.new(1,-12,0,math.min(#res,5)*28+8); rf.Visible = true
        for i, r in ipairs(res) do
            local rb = Instance.new("TextButton")
            rb.Size = UDim2.new(1,0,0,26) rb.BackgroundColor3 = Theme.DropdownBg
            rb.Text = r rb.TextColor3 = Theme.TextPrimary rb.TextSize = 12
            rb.Font = Enum.Font.Gotham rb.BorderSizePixel = 0
            rb.ZIndex = 19 rb.LayoutOrder = i rb.Parent = rf
            Corner(rb, 5)
            HoverEffect(rb, Theme.DropdownBg, Theme.SurfaceHover)
            rb.MouseButton1Click:Connect(function()
                box.Text = r; rf.Visible = false; callback(r)
            end)
        end
    end)
    return { Get = function(_) return box.Text end, Set = function(_, v) box.Text = v end }
end

