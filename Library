	--- Create a new tab.
	--- @param tabName string   Label shown on the sidebar button.
	--- @param icon    string?  Optional emoji/icon prefix for the button label.
	--- @return Tab API table
	function Window:CreateTab(tabName, icon)
		assert(type(tabName) == "string" and #tabName > 0,
			"CreateTab: tabName must be a non-empty string")

		local TabButton = Instance.new("TextButton")
		TabButton.Size = UDim2.new(1, 0, 0, 36)
