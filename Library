                end

                function Tab:AddToggle(ToggleConfig)
                        ToggleConfig = ToggleConfig or {}
                        ToggleConfig.Name = ToggleConfig.Name or "Toggle"
                        ToggleConfig.Default = ToggleConfig.Default or false
                        ToggleConfig.Flag = ToggleConfig.Flag or ""
                        ToggleConfig.Callback = ToggleConfig.Callback or function() end

                        local Toggled = ToggleConfig.Default

                        local Frame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 4), {
                                Size = UDim2.new(1, 0, 0, 26),
                                Parent = Page
                        }), {
                                MakeElement("Padding", 0, 8, 8, 0),
                                AddThemeObject(SetProps(MakeElement("Label", ToggleConfig.Name, 12), { Size = UDim2.new(1, -40, 1, 0), Font = Enum.Font.Gotham }), "Text"),
                                SetProps(MakeElement("Button"), { Size = UDim2.new(1, 16, 1, 0), Position = UDim2.new(0, -8, 0, 0) })
                        }), "Second")

                        local Indicator = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 3), {
                                AnchorPoint = Vector2.new(1, 0.5),
                                Position = UDim2.new(1, 0, 0.5, 0),
                                Size = UDim2.new(0, 12, 0, 12)
                        }), { MakeElement("Corner", 0, 3) }), "Main")
                        Indicator.Parent = Frame

                        local function UpdateToggle(State)
                                Toggled = State
                                if ToggleConfig.Flag ~= "" then Library.Flags[ToggleConfig.Flag].Value = Toggled end
                                if Toggled then
                                        Indicator.BackgroundColor3 = Library.Themes[Library.SelectedTheme].Stroke
                                        Indicator.BackgroundTransparency = 0
                                else
                                        Indicator.BackgroundColor3 = Library.Themes[Library.SelectedTheme].Main
                                        Indicator.BackgroundTransparency = 0.5
                                end
                                ToggleConfig.Callback(Toggled)
                        end

                        AddConnection(Frame.TextButton.MouseButton1Up, function() UpdateToggle(not Toggled) end)
                        if ToggleConfig.Flag ~= "" then
                                Library.Flags[ToggleConfig.Flag] = { Type = "Toggle", Value = Toggled, Save = true, Set = function(self, State) UpdateToggle(State) end }
                        end
                        UpdateToggle(Toggled)
                        return Frame
                end

                function Tab:AddSlider(SliderConfig)
                        SliderConfig = SliderConfig or {}
                        SliderConfig.Name = SliderConfig.Name or "Slider"
                        SliderConfig.Min = SliderConfig.Min or 0
                        SliderConfig.Max = SliderConfig.Max or 100
                        SliderConfig.Default = SliderConfig.Default or 50
                        SliderConfig.Increment = SliderConfig.Increment or 1
                        SliderConfig.Flag = SliderConfig.Flag or ""
                        SliderConfig.Callback = SliderConfig.Callback or function() end

                        local Value = SliderConfig.Default

                        local Frame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 4), {
                                Size = UDim2.new(1, 0, 0, 34),
                                Parent = Page
                        }), {
                                MakeElement("Padding", 0, 8, 8, 0),
                                AddThemeObject(SetProps(MakeElement("Label", SliderConfig.Name, 12), { Size = UDim2.new(1, -60, 0, 18), Font = Enum.Font.Gotham }), "Text")
                        }), "Second")

                        local ValueLabel = AddThemeObject(SetProps(MakeElement("Label", tostring(Value), 11), {
                                Size = UDim2.new(0, 50, 0, 18), Position = UDim2.new(1, 0, 0, 0), TextXAlignment = Enum.TextXAlignment.Right, Font = Enum.Font.Code, Parent = Frame
                        }), "TextDark")

                        local Track = AddThemeObject(Create("Frame", {
                                Size = UDim2.new(1, 0, 0, 2), Position = UDim2.new(0, 0, 0, 24), Parent = Frame, BackgroundTransparency = 0.6
                        }), "Main")
                        
                        local Fill = AddThemeObject(Create("Frame", {
                                Size = UDim2.new(0, 0, 1, 0), Parent = Track, BackgroundTransparency = 0
                        }), "Stroke")

                        local ActiveButton = SetProps(MakeElement("Button"), { Size = UDim2.new(1, 0, 3, -3), Position = UDim2.new(0,0,0,-3), Parent = Track })
                        local Sliding = false

                        local function UpdateSlider(NewValue)
                                Value = math.clamp(Round(NewValue, SliderConfig.Increment), SliderConfig.Min, SliderConfig.Max)
                                ValueLabel.Text = tostring(Value)
                                local Percentage = (Value - SliderConfig.Min) / (SliderConfig.Max - SliderConfig.Min)
                                TweenService:Create(Fill, TweenInfo.new(0.05), {Size = UDim2.new(Percentage, 0, 1, 0)}):Play()
                                if SliderConfig.Flag ~= "" then Library.Flags[SliderConfig.Flag].Value = Value end
                                SliderConfig.Callback(Value)
                        end

                        local function SnapToMouse()
                                local Percent = math.clamp((Mouse.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                                UpdateSlider(SliderConfig.Min + (Percent * (SliderConfig.Max - SliderConfig.Min)))
                        end

                        AddConnection(ActiveButton.InputBegan, function(Input)
                                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then Sliding = true SnapToMouse() end
                        end)
                        AddConnection(UserInputService.InputEnded, function(Input)
                                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then Sliding = false end
                        end)
                        AddConnection(UserInputService.InputChanged, function(Input)
                                if Sliding and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then SnapToMouse() end
                        end)

                        if SliderConfig.Flag ~= "" then
                                Library.Flags[SliderConfig.Flag] = { Type = "Slider", Value = Value, Save = true, Set = function(self, State) UpdateSlider(State) end }
                        end

                        UpdateSlider(Value)
                        return Frame
                end

                function Tab:AddDropdown(DropdownConfig)
                        DropdownConfig = DropdownConfig or {}
                        DropdownConfig.Name = DropdownConfig.Name or "Select"
                        DropdownConfig.Options = DropdownConfig.Options or {}
                        DropdownConfig.Default = DropdownConfig.Default or ""
                        DropdownConfig.Flag = DropdownConfig.Flag or ""
                        DropdownConfig.Callback = DropdownConfig.Callback or function() end

                        local Opened = false
                        local Selected = DropdownConfig.Default

                        local Frame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 4), {
                                Size = UDim2.new(1, 0, 0, 26),
                                Parent = Page,
                                ClipsDescendants = true
                        }), {
                                MakeElement("Padding", 0, 8, 8, 0),
                                AddThemeObject(SetProps(MakeElement("Label", DropdownConfig.Name, 12), { Size = UDim2.new(1, -120, 0, 26), Font = Enum.Font.Gotham }), "Text"),
                                SetProps(MakeElement("Button"), { Size = UDim2.new(1, 16, 0, 26), Position = UDim2.new(0, -8, 0, 0) })
                        }), "Second")

                        local SelectionLabel = AddThemeObject(SetProps(MakeElement("Label", Selected ~= "" and Selected or "[...]", 11), {
                                Size = UDim2.new(0, 100, 0, 26), Position = UDim2.new(1, 0, 0, 0), TextXAlignment = Enum.TextXAlignment.Right, Font = Enum.Font.GothamBold, Parent = Frame
                        }), "Stroke")

                        local OptionsHolder = AddThemeObject(SetChildren(SetProps(MakeElement("TFrame"), {
                                Position = UDim2.new(0, -8, 0, 26), Size = UDim2.new(1, 16, 0, 0), Parent = Frame
                        }), { SetProps(MakeElement("List"), { Padding = UDim.new(0, 2) }) }), "Main")

                        local function ToggleDropdown()
                                Opened = not Opened
                                if Opened then
                                        local Height = (#DropdownConfig.Options * 24) + 4
                                        TweenService:Create(Frame, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, Height + 26)}):Play()
                                        TweenService:Create(OptionsHolder, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, 16, 0, Height)}):Play()
                                else
                                        TweenService:Create(Frame, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, 26)}):Play()
                                        TweenService:Create(OptionsHolder, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, 16, 0, 0)}):Play()
                                end
                        end

                        AddConnection(Frame.TextButton.MouseButton1Up, ToggleDropdown)

                        local function RefreshOptions()
                                for _, c in pairs(OptionsHolder:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                                for _, opt in ipairs(DropdownConfig.Options) do
                                        local OptBtn = AddThemeObject(SetChildren(SetProps(MakeElement("Button"), {
                                                Size = UDim2.new(1, 0, 0, 22), Parent = OptionsHolder
                                        }), {
                                                SetProps(MakeElement("Label", opt, 11), { Size = UDim2.new(1, -10, 1, 0), Position = UDim2.new(0, 10, 0, 0) })
                                        }), "Second")

                                        if opt == Selected then OptBtn.TextLabel.TextColor3 = Library.Themes[Library.SelectedTheme].Stroke end

                                        AddConnection(OptBtn.MouseButton1Up, function()
                                                Selected = opt
                                                SelectionLabel.Text = opt
                                                if DropdownConfig.Flag ~= "" then Library.Flags[DropdownConfig.Flag].Value = Selected end
                                                ToggleDropdown()
                                                DropdownConfig.Callback(Selected)
                                                RefreshOptions()
                                        end)
                                end
                        end

                        function DropdownConfig:Refresh(NewOptions)
                                DropdownConfig.Options = NewOptions
                                RefreshOptions()
                        end

                        if DropdownConfig.Flag ~= "" then
                                Library.Flags[DropdownConfig.Flag] = { Type = "Dropdown", Value = Selected, Save = true, Set = function(self, Value) Selected = Value SelectionLabel.Text = Value DropdownConfig.Callback(Value) RefreshOptions() end }
                        end

                        RefreshOptions()
                        return Frame
                end

                function Tab:AddTextbox(TextboxConfig)
                        TextboxConfig = TextboxConfig or {}
                        TextboxConfig.Name = TextboxConfig.Name or "Input"
                        TextboxConfig.Placeholder = TextboxConfig.Placeholder or "..."
                        TextboxConfig.Default = TextboxConfig.Default or ""
                        TextboxConfig.ClearOnFocus = TextboxConfig.ClearOnFocus or false
                        TextboxConfig.Flag = TextboxConfig.Flag or ""
                        TextboxConfig.Callback = TextboxConfig.Callback or function() end

