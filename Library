                        end)
                        AddConnection(Frame.TextButton.MouseButton1Up, function()
                                TweenService:Create(Frame, TweenInfo.new(0.1), {BackgroundTransparency = 0.15}):Play()
                                BtnConfig.Callback()
                        end)
