		lbl.TextWrapped = true
		lbl.ZIndex = 1001
		lbl.Parent = toast

		toast.GroupTransparency = 1
		Tween(toast, C.TWEEN_MED, {GroupTransparency = 0}):Play()

		task.delay(duration, function()
			local out = Tween(toast, C.TWEEN_FAST, {GroupTransparency = 1})
			out:Play()
			out.Completed:Connect(function() toast:Destroy() end)
		end)
	end

	-- ── INTRO ANIMATION ─────────────────────────────────────────────────────

	local function ShowMainFrame(MainFrame)
		MainFrame.Visible = true
		MainFrame.GroupTransparency = 1
		Tween(MainFrame, C.TWEEN_MED, {GroupTransparency = 0}):Play()
	end

	local function RunIntro(onComplete)
		local IntroGui = Instance.new("ScreenGui")
