                                Size = UDim2.new(1, 0, 0, 26),
                                Parent = Page
                        }), {
                                MakeElement("Padding", 0, 8, 8, 0),
                                AddThemeObject(SetProps(MakeElement("Label", TextboxConfig.Name, 12), { Size = UDim2.new(1, -110, 1, 0), Font = Enum.Font.Gotham }), "Text")
