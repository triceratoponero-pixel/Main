					collapseTween:Play()
					TweenService:Create(base, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(1, 0, 0, 46)}):Play()
					collapseTween.Completed:Connect(function()
						listFrame.Visible = false
					end)
				end
			end)
		end

