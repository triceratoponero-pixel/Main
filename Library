                function Tab:AddKeybind(KeybindConfig)
                        KeybindConfig = KeybindConfig or {}
                        KeybindConfig.Name = KeybindConfig.Name or "Bind"
                        KeybindConfig.Default = KeybindConfig.Default or Enum.KeyCode.Unknown
                        KeybindConfig.Flag = KeybindConfig.Flag or ""
                        KeybindConfig.Callback = KeybindConfig.Callback or function() end

                        local Binding = false
                        local BoundKey = KeybindConfig.Default

                        local Frame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 4), {
                                Size = UDim2.new(1, 0, 0, 26),
                                Parent = Page
                        }), {
                                MakeElement("Padding", 0, 8, 8, 0),
                                AddThemeObject(SetProps(MakeElement("Label", KeybindConfig.Name, 12), { Size = UDim2.new(1, -80, 1, 0), Font = Enum.Font.Gotham }), "Text"),
                                SetProps(MakeElement("Button"), { Size = UDim2.new(1, 16, 1, 0), Position = UDim2.new(0, -8, 0, 0) })
                        }), "Second")

                        local DisplayLabel = AddThemeObject(SetProps(MakeElement("Label", BoundKey.Name:upper(), 11), {
                                Size = UDim2.new(0, 70, 1, 0), Position = UDim2.new(1, 0, 0, 0), TextXAlignment = Enum.TextXAlignment.Right, Font = Enum.Font.Code, Parent = Frame
                        }), "TextDark")

                        AddConnection(Frame.TextButton.MouseButton1Up, function() Binding = true DisplayLabel.Text = "..." end)

                        AddConnection(UserInputService.InputBegan, function(Input)
                                if Binding then
                                        if Input.UserInputType == Enum.UserInputType.Keyboard then
                                                if not CheckKey(BlacklistedKeys, Input.KeyCode) then BoundKey = Input.KeyCode Binding = false DisplayLabel.Text = BoundKey.Name:upper() end
                                        elseif CheckKey(WhitelistedMouse, Input.UserInputType) then
                                                BoundKey = Input.UserInputType Binding = false DisplayLabel.Text = BoundKey.Name:upper()
                                        end
                                        if KeybindConfig.Flag ~= "" and not Binding then Library.Flags[KeybindConfig.Flag].Value = BoundKey end
                                else
                                        if Input.KeyCode == BoundKey or Input.UserInputType == BoundKey then KeybindConfig.Callback() end
                                end
                        end)

                        if KeybindConfig.Flag ~= "" then
                                Library.Flags[KeybindConfig.Flag] = { Type = "Keybind", Value = BoundKey, Save = true, Set = function(self, State) BoundKey = State DisplayLabel.Text = BoundKey.Name:upper() end }
                        end
                        return Frame
                end

                function Tab:AddColorpicker(CpConfig)
                        CpConfig = CpConfig or {}
                        CpConfig.Name = CpConfig.Name or "Color"
                        CpConfig.Default = CpConfig.Default or Color3.fromRGB(255, 255, 255)
                        CpConfig.Flag = CpConfig.Flag or ""
                        CpConfig.Callback = CpConfig.Callback or function() end

                        local CurrentColor = CpConfig.Default
                        local Op = false

                        local Frame = AddThemeObject(SetChildren(SetProps(MakeElement("RoundFrame", Color3.fromRGB(255, 255, 255), 0, 4), {
                                Size = UDim2.new(1, 0, 0, 26),
                                Parent = Page,
                                ClipsDescendants = true
                        }), {
                                MakeElement("Padding", 0, 8, 8, 0),
                                AddThemeObject(SetProps(MakeElement("Label", CpConfig.Name, 12), { Size = UDim2.new(1, -60, 0, 26), Font = Enum.Font.Gotham }), "Text"),
                                SetProps(MakeElement("Button"), { Size = UDim2.new(1, 16, 0, 26), Position = UDim2.new(0, -8, 0, 0) })
                        }), "Second")

                        local Preview = SetProps(MakeElement("RoundFrame", CurrentColor, 0, 2), {
                                AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, 0, 0, 13), Size = UDim2.new(0, 16, 0, 10), Parent = Frame
                        })

                        local PickerModule = AddThemeObject(SetProps(MakeElement("TFrame"), { Position = UDim2.new(0, -8, 0, 26), Size = UDim2.new(1, 16, 0, 80), Parent = Frame }), "Main")
                        local Palette = Create("ImageButton", { Size = UDim2.new(1, -24, 1, -10), Position = UDim2.new(0, 8, 0, 5), Image = "rbxassetid://4155135233", Parent = PickerModule })
                        local HueSlider = Create("ImageButton", { Size = UDim2.new(0, 8, 1, -10), Position = UDim2.new(1, -12, 0, 5), Image = "rbxassetid://3641079629", Parent = PickerModule })

                        local function TogglePalette()
                                Op = not Op
                                if Op then TweenService:Create(Frame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 106)}):Play()
                                else TweenService:Create(Frame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 26)}):Play() end
                        end

                        AddConnection(Frame.TextButton.MouseButton1Up, TogglePalette)

                        local h, s, v = CurrentColor:ToHSV()
                        local function UpdateColors()
                                CurrentColor = Color3.fromHSV(h, s, v)
                                Preview.BackgroundColor3 = CurrentColor
                                if CpConfig.Flag ~= "" then Library.Flags[CpConfig.Flag].Value = CurrentColor end
                                CpConfig.Callback(CurrentColor)
                        end

                        local PaletteActive, HueActive = false, false
                        AddConnection(Palette.InputBegan, function(Input) if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then PaletteActive = true end end)
                        AddConnection(HueSlider.InputBegan, function(Input) if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then HueActive = true end end)
                        AddConnection(UserInputService.InputEnded, function(Input) if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then PaletteActive = false HueActive = false end end)

                        AddConnection(UserInputService.InputChanged, function(Input)
                                if PaletteActive and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                                        s = math.clamp((Input.Position.X - Palette.AbsolutePosition.X) / Palette.AbsoluteSize.X, 0, 1)
                                        v = 1 - math.clamp((Input.Position.Y - Palette.AbsolutePosition.Y) / Palette.AbsoluteSize.Y, 0, 1)
                                        UpdateColors()
                                elseif HueActive and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                                        h = 1 - math.clamp((Input.Position.Y - HueSlider.AbsolutePosition.Y) / HueSlider.AbsoluteSize.Y, 0, 1)
                                        UpdateColors()
                                end
                        end)

                        if CpConfig.Flag ~= "" then
                                Library.Flags[CpConfig.Flag] = { Type = "Colorpicker", Value = CurrentColor, Save = true, Set = function(self, State) CurrentColor = State h, s, v = CurrentColor:ToHSV() Preview.BackgroundColor3 = CurrentColor CpConfig.Callback(CurrentColor) end }
                        end
                        return Frame
                end

                table.insert(Window.Tabs, Tab)
                return Tab
        end

        local function _configPath(name) return WindowConfig.ConfigFolder .. "/configs/" .. name .. ".txt" end
        local function _ensureFolders() if not isfolder(WindowConfig.ConfigFolder) then makefolder(WindowConfig.ConfigFolder) end if not isfolder(WindowConfig.ConfigFolder .. "/configs") then makefolder(WindowConfig.ConfigFolder .. "/configs") end end
        local function _checkExecutor() return (writefile and readfile and isfile and isfolder and makefolder and listfiles) end

        function Library:SaveConfig(name)
                if not name or name == "" or not _checkExecutor() then return false end
                pcall(function()
                        _ensureFolders() local Data = {}
                        for i, v in pairs(Library.Flags) do if v.Save then Data[i] = (v.Type == "Colorpicker" and PackColor(v.Value) or v.Value) end end
                        writefile(_configPath(name), HttpService:JSONEncode(Data))
                end)
                return true
        end

        function Library:LoadConfig(name)
                if not name or name == "" or not _checkExecutor() then return false end
                local path = _configPath(name) if not isfile(path) then return false end
                local ok, content = pcall(readfile, path) if not ok then return false end
                LoadCfg(content) return true
        end

        function Library:DeleteConfig(name)
                if not name or name == "" or not _checkExecutor() then return false end
                local path = _configPath(name) if not isfile(path) then return false end
                if delfile then pcall(delfile, path) return true end return false
        end

        function Library:GetConfigId(name)
                if not name or name == "" or not _checkExecutor() then return "" end
                local path = _configPath(name) if not isfile(path) then return "" end
                local ok, raw = pcall(readfile, path) if not ok then return "" end
                return HttpService:JSONEncode({raw = raw})
        end

        function Library:SaveConfigId(name, id)
                if not name or name == "" or not id or id == "" or not _checkExecutor() then return false end
                local ok = pcall(function() _ensureFolders() local raw = HttpService:JSONDecode(id).raw writefile(_configPath(name), raw) end)
                return ok
        end

        function Library:ListConfigs()
                if not _checkExecutor() then return {} end
                local list = {}
                local ok, files = pcall(listfiles, WindowConfig.ConfigFolder .. "/configs")
                if not ok or not files then return list end
                for _, file in ipairs(files) do
                        local n = file:match("([^/\\\.]+)%.txt$") or file:match("([^%\\]+)%.txt$")
                        if n then table.insert(list, n) end
                end
                return list
        end

        return Window
end

return Library
