		TabButton.TextSize = 13
		TabButton.Parent = TabButtonsContainer
		RoundFrame(TabButton, 6)

		-- Active indicator — a small vertical bar on the left edge
		local TabIndicator = Instance.new("Frame")
		TabIndicator.Size = UDim2.new(0, 3, 0, 0)
		TabIndicator.Position = UDim2.new(0, 0, 0.5, 0)
		TabIndicator.AnchorPoint = Vector2.new(0, 0.5)
		TabIndicator.BackgroundColor3 = T.Accent
		TabIndicator.BorderSizePixel = 0
		TabIndicator.Parent = TabButton
		RoundFrame(TabIndicator, 999)

		-- Scrollable content canvas for this tab
		local TabContent = Instance.new("CanvasGroup")
		TabContent.Size = UDim2.new(1, -32, 1, -32)
		TabContent.Position = UDim2.new(0, 16, 0, 16)
		TabContent.BackgroundTransparency = 1
		TabContent.Visible = false
		TabContent.GroupTransparency = 0
		TabContent.ClipsDescendants = false
		TabContent.Parent = TabsFolder

		local ScrollFrame = Instance.new("ScrollingFrame")
		ScrollFrame.Size = UDim2.new(1, 0, 1, 0)
		ScrollFrame.BackgroundTransparency = 1
		ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
		ScrollFrame.ScrollBarThickness = 3
		ScrollFrame.ScrollBarImageColor3 = T.Scrollbar
		ScrollFrame.ClipsDescendants = false
		ScrollFrame.Parent = TabContent

		local ContentLayout = Instance.new("UIListLayout")
		ContentLayout.Padding = UDim.new(0, 8)
		ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
		ContentLayout.Parent = ScrollFrame

		Track(ContentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			ScrollFrame.CanvasSize =
				UDim2.new(0, 0, 0, ContentLayout.AbsoluteContentSize.Y + 15)
		end))

		-- Auto-select the first tab created
		if isFirstTab then
			TabContent.Visible = true
			TabButton.BackgroundColor3 = T.ElementHover
			TabButton.TextColor3 = T.TextPrimary
			TabIndicator.Size = UDim2.new(0, 3, 0, 18)
			isFirstTab = false
		end

		local function SelectThisTab()
			-- Fade out every other visible tab
			for _, child in pairs(TabsFolder:GetChildren()) do
				if child:IsA("CanvasGroup") and child.Visible and child ~= TabContent then
					local out = Tween(child, C.TWEEN_FAST, {GroupTransparency = 1})
					out:Play()
					out.Completed:Once(function() child.Visible = false end)
				end
			end
			-- Deactivate all sidebar buttons
			for _, btn in pairs(TabButtonsContainer:GetChildren()) do
				if btn:IsA("TextButton") then
					Tween(btn, C.TWEEN_FAST, {
						BackgroundColor3 = T.Surface,
						TextColor3       = T.TextMuted,
					}):Play()
					local ind = btn:FindFirstChildWhichIsA("Frame")
					if ind then
						Tween(ind, C.TWEEN_FAST, {Size = UDim2.new(0, 3, 0, 0)}):Play()
					end
				end
			end
			-- Show this tab
			TabContent.GroupTransparency = 1
			TabContent.Visible = true
			Tween(TabContent, C.TWEEN_MED, {GroupTransparency = 0}):Play()
			Tween(TabButton, C.TWEEN_FAST, {
				BackgroundColor3 = T.ElementHover,
				TextColor3       = T.TextPrimary,
			}):Play()
			Tween(TabIndicator, C.TWEEN_FAST, {Size = UDim2.new(0, 3, 0, 18)}):Play()
		end

		TabButton.MouseButton1Click:Connect(SelectThisTab)

