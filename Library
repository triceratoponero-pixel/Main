-- ─── INTERNAL HELPERS ─────────────────────────────────────────────────────────
-- Small utilities used throughout the library.

--- Shorthand for TweenService:Create to reduce verbosity.
local function Tween(inst, info, props)
	return TweenService:Create(inst, info, props)
end

--- Attach a UICorner to a frame.  radius defaults to C.CORNER_RADIUS.
local function RoundFrame(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or C.CORNER_RADIUS)
	c.Parent = parent
	return c
end

--- Attach a UIStroke to a frame.
local function Stroke(parent, color, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color or Color3.fromRGB(45, 45, 45)
	s.Thickness = thickness or 1
	s.Parent = parent
	return s
end

--- Clamp a Color3's HSV saturation and value to [0,1] to ensure it is valid.
--- Returns a corrected Color3.
local function ClampColor(color)
	local h, s, v = color:ToHSV()
	s = math.clamp(s, 0, 1)
	v = math.clamp(v, 0, 1)
	return Color3.fromHSV(h, s, v)
end

--- Safely disconnect all connections in a list.
local function DisconnectAll(list)
	for _, conn in ipairs(list) do
		pcall(function() conn:Disconnect() end)
	end
end

-- ─── MAIN LIBRARY ─────────────────────────────────────────────────────────────

local GhostLib = {}
GhostLib.__index = GhostLib

--- Create a new UI window.
---
--- @param options table
---   .Title        string              Window title shown in the topbar.
---   .Theme        string              Theme name ("Dark").  Defaults to "Dark".
---   .SkipIntro    boolean             Skip the ghost intro animation.
---   .IntroDuration number             Duration of the intro in seconds (default 4.0).
---   .ToggleKey    Enum.KeyCode        Key that hides / shows the window (default RightControl).
--- @return Window API table
function GhostLib:CreateWindow(options)
	options = options or {}

	-- ── Resolve options with safe defaults ──────────────────────────────────
	local themeName   = type(options.Theme)        == "string"  and options.Theme        or "Dark"
	local skipIntro   = options.SkipIntro == true
	local introDur    = type(options.IntroDuration) == "number" and options.IntroDuration or 4.0
	local windowTitle = type(options.Title)         == "string" and options.Title         or "GHOSTWARE"
	local toggleKey   = options.ToggleKey or Enum.KeyCode.RightControl

	-- Resolve theme, fall back to Dark if the name is unknown
	local T = Themes[themeName]
	if not T then
		warn("GhostLib: Unknown theme '" .. tostring(themeName) .. "', falling back to Dark.")
		T = Themes.Dark
	end

	-- ── Connection tracker ───────────────────────────────────────────────────
	-- Every RBXScriptConnection is stored here so we can cleanly disconnect
	-- everything when the window is destroyed.
	local _connections = {}
	local function Track(conn)
		table.insert(_connections, conn)
		return conn
	end

	-- ── ScreenGui root ───────────────────────────────────────────────────────
	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "GhostUI_PremiumDark"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	ScreenGui.IgnoreGuiInset = true
	ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

	-- ═══════════════════════════════════════════════════════════════════════
	--  NOTIFICATION / TOAST SYSTEM
	--  Toasts stack at the bottom-right corner of the screen.  Each toast
	--  fades in, waits for `duration` seconds, then fades out and destroys
	--  itself.  Supported styles: "info" | "success" | "error" | "warning"
	-- ═══════════════════════════════════════════════════════════════════════

	local ToastContainer = Instance.new("Frame")
	ToastContainer.Name = "ToastContainer"
	ToastContainer.Size = UDim2.new(0, 280, 1, 0)
	ToastContainer.Position = UDim2.new(1, -296, 0, 0)
	ToastContainer.BackgroundTransparency = 1
	ToastContainer.ZIndex = 999
	ToastContainer.Parent = ScreenGui

	local ToastLayout = Instance.new("UIListLayout")
	ToastLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
	ToastLayout.Padding = UDim.new(0, 8)
	ToastLayout.Parent = ToastContainer

	local ToastPadding = Instance.new("UIPadding")
	ToastPadding.PaddingBottom = UDim.new(0, 12)
	ToastPadding.Parent = ToastContainer

	--- Show a toast notification.
	---
	--- @param msg      string   The message to display.
	--- @param style    string?  "info" | "success" | "error" | "warning"
	--- @param duration number?  Seconds before the toast fades (default 3).
	local function Notify(msg, style, duration)
		-- Input validation / defaults
		if type(msg) ~= "string" then msg = tostring(msg) end
		style    = (style == "success" or style == "error" or style == "warning") and style or "info"
		duration = type(duration) == "number" and math.max(0.5, duration) or 3

		local accent = style == "success" and T.Success
			or style == "error"   and T.Error
			or style == "warning" and T.Warning
			or T.Accent

		local toast = Instance.new("CanvasGroup")
		toast.Size = UDim2.new(1, 0, 0, 48)
		toast.BackgroundColor3 = T.Toast
		toast.BorderSizePixel = 0
		toast.ZIndex = 1000
		toast.ClipsDescendants = false
		toast.Parent = ToastContainer
		RoundFrame(toast, 8)
		Stroke(toast, T.Border)

		-- Left accent bar indicates style type visually
		local bar = Instance.new("Frame")
		bar.Size = UDim2.new(0, 3, 1, -16)
		bar.Position = UDim2.new(0, 8, 0.5, 0)
		bar.AnchorPoint = Vector2.new(0, 0.5)
		bar.BackgroundColor3 = accent
		bar.BorderSizePixel = 0
		bar.ZIndex = 1001
		bar.Parent = toast
		RoundFrame(bar, 2)

		local lbl = Instance.new("TextLabel")
		lbl.Size = UDim2.new(1, -28, 1, 0)
		lbl.Position = UDim2.new(0, 22, 0, 0)
		lbl.BackgroundTransparency = 1
		lbl.Text = msg
		lbl.FontFace = Font.new("rbxasset://fonts/families/Montserrat.json")
		lbl.TextSize = 12
		lbl.TextColor3 = T.TextSecondary
		lbl.TextXAlignment = Enum.TextXAlignment.Left
		lbl.TextWrapped = true
		lbl.ZIndex = 1001
		lbl.Parent = toast

		-- Animate in
		toast.GroupTransparency = 1
		Tween(toast, C.TWEEN_MED, {GroupTransparency = 0}):Play()

		-- Auto-dismiss
		task.delay(duration, function()
			if not toast or not toast.Parent then return end
			local out = Tween(toast, C.TWEEN_FAST, {GroupTransparency = 1})
			out:Play()
			out.Completed:Once(function() pcall(function() toast:Destroy() end) end)
		end)
	end

	-- ═══════════════════════════════════════════════════════════════════════
	--  INTRO ANIMATION
	--  A ghost character sweeps left-to-right across the "GHOST" title.
	--  When the ghost's centre X overlaps each letter, that letter:
	--    1. Slams down, flips, turns black with a white UIStroke outline
	--    2. Bounces back up with elastic easing, returns to white
	--  After introDur seconds the scene fades out and onComplete() is called.
	-- ═══════════════════════════════════════════════════════════════════════

	local function ShowMainFrame(MainFrame)
		MainFrame.Visible = true
		MainFrame.GroupTransparency = 1
		Tween(MainFrame, C.TWEEN_MED, {GroupTransparency = 0}):Play()
	end

	local function RunIntro(onComplete)
		local IntroGui = Instance.new("ScreenGui")
		IntroGui.Name = "GhostIntro_Layer"
		IntroGui.IgnoreGuiInset = true
		IntroGui.ResetOnSpawn = false
		IntroGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		IntroGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

		local IntroContainer = Instance.new("Frame")
		IntroContainer.Size = UDim2.new(1, 0, 1, 0)
		IntroContainer.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
		IntroContainer.BorderSizePixel = 0
		IntroContainer.ZIndex = 100
		IntroContainer.Parent = IntroGui

		-- Centred frame that holds the animated letters
		local TextSequenceFrame = Instance.new("Frame")
		TextSequenceFrame.Size = UDim2.new(0, 600, 0, 150)
		TextSequenceFrame.Position = UDim2.new(0.5, -300, 0.5, -75)
		TextSequenceFrame.BackgroundTransparency = 1
		TextSequenceFrame.ZIndex = 101
		TextSequenceFrame.Parent = IntroContainer

		-- Build one LetterObject per character in "GHOST"
		local Characters = {"G","H","O","S","T"}
		local LetterObjects = {}
		local charWidth = 120

		for i, char in ipairs(Characters) do
			local LetterContainer = Instance.new("Frame")
			LetterContainer.Size = UDim2.new(0, charWidth, 1, 0)
			LetterContainer.Position = UDim2.new(0, (i - 1) * charWidth, 0, 0)
			LetterContainer.BackgroundTransparency = 1
			LetterContainer.ZIndex = 102
			LetterContainer.Parent = TextSequenceFrame

			local TextLabel = Instance.new("TextLabel")
			TextLabel.Size = UDim2.new(1, 0, 1, 0)
			TextLabel.BackgroundTransparency = 1
			TextLabel.Text = char
			TextLabel.Font = Enum.Font.Montserrat
			TextLabel.TextSize = 120
			TextLabel.TextColor3 = Color3.fromRGB(245, 245, 245)
			TextLabel.ZIndex = 103
			TextLabel.FontFace = Font.new(
				"rbxasset://fonts/families/Montserrat.json",
				Enum.FontWeight.Bold
			)
			TextLabel.Parent = LetterContainer

			-- UIStroke used for the white-outline effect when the ghost hits the letter
			local GlowStroke = Instance.new("UIStroke")
			GlowStroke.Thickness = 0
			GlowStroke.Color = Color3.fromRGB(245, 245, 245)
			GlowStroke.Transparency = 1
			GlowStroke.Parent = TextLabel

			table.insert(LetterObjects, {
				Container = LetterContainer,
				Label     = TextLabel,
				Stroke    = GlowStroke,
				Hit       = false,
			})
		end

		-- ── Ghost character ──────────────────────────────────────────────────
		local Ghost = Instance.new("CanvasGroup")
		Ghost.Name = "Ghost"
		Ghost.Size = UDim2.new(0, 85, 0, 110)
		Ghost.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
		Ghost.ZIndex = 105
		Ghost.Parent = TextSequenceFrame
		Ghost.Position = UDim2.new(0, -160, 0.5, -55)
		RoundFrame(Ghost, 42)

		local Eye1 = Instance.new("Frame")
		Eye1.Size = UDim2.new(0, 9, 0, 13)
		Eye1.Position = UDim2.new(0.32, -4, 0.38, -6)
		Eye1.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
		Eye1.BorderSizePixel = 0
		Eye1.Parent = Ghost
		RoundFrame(Eye1, 999)

		local eyeShine1 = Instance.new("Frame")
		eyeShine1.Size = UDim2.new(0, 3, 0, 3)
		eyeShine1.Position = UDim2.new(0.4, -1, 0.25, -1)
		eyeShine1.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
		eyeShine1.BorderSizePixel = 0
		eyeShine1.Parent = Eye1
		RoundFrame(eyeShine1, 999)

		local Eye2 = Eye1:Clone()
		Eye2.Position = UDim2.new(0.68, -4, 0.38, -6)
		Eye2.Parent = Ghost

		local eyeShine2 = eyeShine1:Clone()
		eyeShine2.Parent = Eye2

		local Mouth = Instance.new("Frame")
		Mouth.Size = UDim2.new(0, 11, 0, 11)
		Mouth.Position = UDim2.new(0.5, -5, 0.58, -5)
		Mouth.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
		Mouth.BorderSizePixel = 0
		Mouth.Parent = Ghost
		RoundFrame(Mouth, 999)

		-- Wavy tentacles at the bottom of the ghost
		local Tentacles = {}
		local waveWidth = 1 / 5
		for i = 1, 5 do
			local wave = Instance.new("Frame")
			wave.Size = UDim2.new(waveWidth, 2, 0, 22)
			wave.Position = UDim2.new(waveWidth * (i - 1), -1, 1, -10)
			wave.BackgroundColor3 = (i == 2 or i == 4)
				and Color3.fromRGB(15, 15, 15)
				or  Color3.fromRGB(245, 245, 245)
			wave.BorderSizePixel = 0
			wave.Parent = Ghost
			RoundFrame(wave, 999)
			table.insert(Tentacles, wave)
		end

		-- Ghost enters with a pop (scale up) before its linear sweep
		Ghost.Size = UDim2.new(0, 30, 0, 40)
		Ghost.GroupTransparency = 1
		Tween(Ghost, TweenInfo.new(0.5, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {
			Size              = UDim2.new(0, 85, 0, 110),
			GroupTransparency = 0,
		}):Play()

		-- Primary sweep across the title
		local ghostTween = Tween(Ghost,
			TweenInfo.new(introDur, Enum.EasingStyle.Linear),
			{Position = UDim2.new(0, 660, 0.5, -55)}
		)
		ghostTween:Play()

		-- ── Per-frame animation loop ─────────────────────────────────────────
		local runTime = 0
		local animConn

		animConn = RunService.Heartbeat:Connect(function(dt)
			runTime += dt
			local phase     = runTime * 3.2  * math.pi * 2
			local floatPh   = runTime * 1.5  * math.pi * 2
			local bobPh     = runTime * 2.8  * math.pi * 2
			local blinkPh   = runTime * 4.2

			if Ghost and Ghost:IsDescendantOf(game) then
				-- Body squash & stretch
				local scaleX = 85 + math.sin(phase) * 14 + math.sin(floatPh * 0.5) * 8
				local scaleY = 110 - math.sin(phase) * 12 + math.cos(bobPh) * 10
				Ghost.Size = UDim2.new(0, scaleX, 0, scaleY)

				-- Slight wobble rotation
				Ghost.Rotation = math.sin(phase * 0.7) * 3

				-- Tentacle waves
				for idx, wave in ipairs(Tentacles) do
					local v = idx * 0.4
					local rot    = math.sin(phase + v) * 28 + math.cos(phase * 1.5 + v) * 12
					local height = 22 + math.sin(phase + v) * 9 + math.cos(floatPh + v * 0.5) * 7
					wave.Rotation = rot
					wave.Size = UDim2.new(
						waveWidth,
						2 + math.abs(math.sin(phase + v)),
						0,
						math.max(15, height)
					)
				end

				-- Eye blink
				local blinkAmt = math.max(0, math.sin(blinkPh * 2) ^ 2)
				Eye1.Size = UDim2.new(0, 9, 0, math.max(1, 13 * (1 - blinkAmt)))
				Eye2.Size = UDim2.new(0, 9, 0, math.max(1, 13 * (1 - blinkAmt)))

				-- Eye-shine pulse
				local shine = (math.sin(phase * 2) + 1) * 0.5
				eyeShine1.Size = UDim2.new(0, 3 + shine * 2, 0, 3 + shine * 2)
				eyeShine2.Size = UDim2.new(0, 3 + shine * 2, 0, 3 + shine * 2)
				eyeShine1.BackgroundTransparency = 0.3 - shine * 0.2
				eyeShine2.BackgroundTransparency = 0.3 - shine * 0.2

				-- Eye drift
				local ex = math.sin(phase * 0.6) * 2
				local ey = math.cos(floatPh * 0.5) * 2
				Eye1.Position = UDim2.new(0.32 + ex * 0.02, -4, 0.38 + ey * 0.02, -6)
				Eye2.Position = UDim2.new(0.68 + ex * 0.02, -4, 0.38 + ey * 0.02, -6)

				-- Mouth open/close
				local mouthOpen = (math.sin(blinkPh * 1.5) + 1) * 0.5
				Mouth.Size = UDim2.new(0, 11, 0, 6 + mouthOpen * 5)
				Mouth.Position = UDim2.new(0.5, -5, 0.58 + mouthOpen * 0.04, -5)
			end

			-- ── Letter hit detection ─────────────────────────────────────────
			-- When the ghost's centre X reaches a letter's centre X, we trigger
			-- a three-phase animation:
			--   Phase 1 — slam: letter moves down, flips 180°, turns BLACK with a
			--             WHITE UIStroke outline (the "ghost hits it" moment).
			--   Phase 2 — bounce: letter springs back with elastic easing,
			--             completes the rotation to 360° and returns WHITE.
			--   Phase 3 — stroke fades out.
			local gx = Ghost.AbsolutePosition.X + Ghost.AbsoluteSize.X / 2
			for _, data in ipairs(LetterObjects) do
				if not data.Hit then
					local lx = data.Container.AbsolutePosition.X + data.Container.AbsoluteSize.X / 2
					if gx >= lx then
						data.Hit = true
						task.spawn(function()
							local orig = data.Label.Position

							-- Phase 1: slam down — letter goes BLACK with white outline
							local slam = Tween(data.Label,
								TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.In),
								{
									Position   = orig + UDim2.new(0, -15, 0, 65),
									Rotation   = 180,
									TextColor3 = Color3.fromRGB(0, 0, 0),   -- black text
								}
							)
							slam:Play()

							-- White outline appears on slam
							Tween(data.Stroke, TweenInfo.new(0.1), {
								Thickness    = 5,
								Transparency = 0,
								Color        = Color3.fromRGB(245, 245, 245),
							}):Play()

							-- Phase 2: bounce back — text returns WHITE, stroke stays briefly
							task.wait(0.2)
							Tween(data.Label,
								TweenInfo.new(0.5, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out),
								{
									Position   = orig,
									Rotation   = 360,
									TextColor3 = Color3.fromRGB(245, 245, 245),
								}
							):Play()

							-- Phase 3: fade stroke out
							task.wait(0.15)
							Tween(data.Stroke,
								TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
								{Thickness = 0, Transparency = 1}
							):Play()
						end)
					end
				end
			end
		end)

		-- ── Outro ────────────────────────────────────────────────────────────
		task.delay(introDur, function()
			animConn:Disconnect()

			-- Staggered letter fade-out with rotation
			for i, data in ipairs(LetterObjects) do
				task.delay(i * 0.05, function()
					Tween(data.Label,  TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
						TextTransparency = 1,
						Rotation         = data.Label.Rotation + 180,
					}):Play()
					Tween(data.Stroke, TweenInfo.new(0.25), {Transparency = 1}):Play()
				end)
			end

			-- Ghost shrinks and fades
			Tween(Ghost, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
				GroupTransparency = 1,
				Size              = UDim2.new(0, 40, 0, 50),
			}):Play()

			-- Background fades out then calls onComplete
			task.wait(0.3)
			local fade = Tween(IntroContainer,
				TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{BackgroundTransparency = 1}
			)
			fade:Play()
			fade.Completed:Once(function()
				pcall(function() IntroGui:Destroy() end)
				onComplete()
			end)
		end)
	end

